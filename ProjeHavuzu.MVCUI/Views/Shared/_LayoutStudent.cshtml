@using Microsoft.AspNetCore.Identity
@using ProjeHavuzu.Data.Entites.Identity
@inject UserManager<AppUser> UserManager
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Proje Havuz Sistemi</title>
    <link href="~/images/oik_favicon.png" rel="icon" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/home.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { line-height: 1.6 !important; }
        .sidebar-logo { max-width: 100px !important; margin-bottom: 1.5rem !important; }
        .sidebar-header { padding: 1.5rem !important; text-align: center !important; border-bottom: 1px solid rgba(255, 255, 255, 0.1) !important; background-color: rgba(0, 0, 0, 0.1) !important; }
        h3 { display: block !important; font-size: 1.17rem !important; font-weight: bold !important; }
        .text-muted { color: white !important; }
        .rotate-chevron { transform: rotate(180deg); transition: transform 0.2s; }
    </style>
</head>
<body>
    <div class="app-container">
        <aside id="sidebar" class="sidebar">
            <div class="sidebar-header text-center p-3">
                <img src="~/images/mtu-logo.png" alt="Logo" class="sidebar-logo mb-2" />
                <h3 class="h5 mb-1">Proje Havuz Sistemi</h3>
                <small style="font-weight:bold;" class="text-muted">Öğrenci Paneli</small>
            </div>
            <nav class="sidebar-nav">
                <ul class="nav flex-column h-100" style="display: flex; flex-direction: column; min-height: 80vh;">
                    <li class="nav-item">
                        <a href="@Url.Action("Index", "Home")">
                            <i class="fas fa-home"></i>
                            <span>Ana Sayfa</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Account/AccountProfile">
                            <i class="bi bi-person-badge"></i>
                            <span>Profilim</span>
                        </a>
                    </li>
                    <li class="accordion-item">
                        <button type="button" class="accordion-toggle">
                            <i class="bi bi-folder"></i>
                            <span>Proje İşlemleri</span>
                            <i class="bi bi-chevron-down ms-auto"></i>
                        </button>
                        <ul class="accordion-menu">
                            <li class="nav-item">
                                <a class="nav-link" href="/Project/Index">
                                    <i class="bi bi-list-check"></i>
                                    <span>Projelerim</span>
                                </a>
                            </li>
                        </ul>
                    </li>
                    <li class="nav-item" style="margin-top: auto !important; padding-bottom: 20px;">
                        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                            <button type="submit" class="logout-btn" style="width:100%; border:none; background:none; text-align:left; padding:10px 20px; color:white;">
                                <i class="fas fa-sign-out-alt"></i> <span><a href="~/Account/Logout"> Çıkış Yap</a> </span>
                            </button>
                        </form>
                    </li>
                </ul>
            </nav>
        </aside>
        <div class="main-content">
            <header class="main-header">
                <button class="sidebar-toggle"><i class="fas fa-bars"></i></button>
                <div class="header-title">
                    <h1>Hoş Geldiniz, 
                        @{
                            var user = User.Identity?.Name != null ? UserManager.FindByNameAsync(User.Identity.Name).Result : null;
                            var displayName = user != null ? user.FullName.ToUpper() : "Misafir";
                        }
                        @displayName
                    </h1>
                </div>
            </header>
            <main class="page-content">@RenderBody()</main>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    <script>
        document.querySelectorAll('.accordion-menu').forEach(ul => ul.style.display = 'none');
        document.querySelectorAll('.accordion-toggle').forEach(btn => {
            btn.addEventListener('click', function () {
                const menu = btn.nextElementSibling;
                const chevron = btn.querySelector('.bi-chevron-down');
                document.querySelectorAll('.accordion-menu').forEach(ul => { if (ul !== menu) ul.style.display = 'none'; });
                document.querySelectorAll('.accordion-toggle .bi-chevron-down').forEach(icn => { if (icn !== chevron) icn.classList.remove('rotate-chevron'); });
                const isOpen = menu.style.display === 'block';
                menu.style.display = isOpen ? 'none' : 'block';
                chevron.classList.toggle('rotate-chevron', !isOpen);
            });
        });
        document.querySelector('.sidebar-toggle').addEventListener('click', function () {
            document.getElementById('sidebar').classList.toggle('active');
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
