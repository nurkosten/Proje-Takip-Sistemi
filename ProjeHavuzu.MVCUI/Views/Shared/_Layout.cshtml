@using Microsoft.AspNetCore.Identity
@using ProjeHavuzu.Data.Entites.Identity
@inject UserManager<AppUser> UserManager
<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Proje Takip Sistemi</title>

    <link href="~/images/oik_favicon.png" rel="icon" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/css/home.css" />
    <link rel="stylesheet" href="~/css/datatable-theme.css" />
    <link rel="stylesheet" href="~/css/responsive.css" />
    <link rel="stylesheet" href="~/css/animations.css" />

    <style>
        /* Template'den gelen özel stiller */
        body {
            line-height: 1.6 !important;
        }

        .sidebar-logo {
            max-width: 100px !important;
            margin: 0 auto 1.5rem auto !important;
            display: block;
        }

        .sidebar-header {
            padding: 1.5rem !important;
            text-align: center !important;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1) !important;
            background-color: rgba(0, 0, 0, 0.1) !important;
        }

        h3 {
            display: block !important;
            font-size: 1.17rem !important;
            font-weight: bold !important;
        }

        .text-muted {
            color: white !important;
        }

        .rotate-chevron {
            transform: rotate(180deg);
            transition: transform 0.2s;
        }
    </style>
</head>

<body>
    <div class="app-container">
        <aside id="sidebar" class="sidebar">
            <div class="sidebar-header text-center p-3">
                <img src="~/images/mtu-logo.png" alt="Logo" class="sidebar-logo mb-2" />
                <h3 class="h5 mb-1">Proje Takip Sistemi</h3>
                <small style="font-weight:bold;" class="text-muted">Yönetim Paneli</small>
            </div>
            <nav class="sidebar-nav">

                <ul class="nav flex-column h-100" style="display: flex; flex-direction: column; min-height: 80vh;">
                    <li class="nav-item">
                        <a href="@Url.Action("Index", "Home")">
                            <i class="fas fa-home"></i>
                            <span>Ana Sayfa</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/Account/AccountProfile">
                            <i class="bi bi-person-badge"></i>
                            <span>Profilim</span>
                        </a>
                    </li>
                    @{
                        if (User.IsInRole("Admin"))
                        {

                            <li class="nav-item">
                                <a class="nav-link" href="/Faculty/Index">
                                    <i class="bi bi-person-badge"></i>
                                    <span>Fakülteler</span>
                                </a>
                            </li>


                            <li class="nav-item">
                                <a class="nav-link" href="/Department/Index">
                                    <i class="bi bi-person-badge"></i>
                                    <span>Bölümler</span>
                                </a>
                            </li>

                            <!-- Hangfire Dashboard - Sadece Admin -->
                            <li class="nav-item">
                                <a class="nav-link" href="/hangfire" target="_blank">
                                    <i class="bi bi-gear-wide-connected"></i>
                                    <span>Hangfire Jobs</span>
                                </a>
                            </li>
                        }
                    }


                    @if (User.IsInRole("Student"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Student/ProjectPool">
                                <i class="bi bi-collection"></i>
                                <span>Proje Havuzu</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Student/MyRequests">
                                <i class="bi bi-inbox"></i>
                                <span>İsteklerim</span>
                            </a>
                        </li>
                    }

                    <li class="accordion-item">
                        <button type="button" class="accordion-toggle">
                            <i class="bi bi-folder"></i>
                            <span>Proje İşlemleri</span>
                            <i class="bi bi-chevron-down ms-auto"></i>
                        </button>
                        <ul class="accordion-menu">
                            <li class="nav-item">
                                <a class="nav-link" href="/Project/Create">
                                    <i class="bi bi-plus-circle"></i>
                                    <span>Yeni Proje Ekle</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/Project/Index">
                                    <i class="bi bi-list-check"></i>
                                    <span>Projelerim</span>
                                </a>
                            </li>
                            @if (User.IsInRole("Teacher") || User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" href="/Teacher/ProjectRequests">
                                        <i class="bi bi-envelope-plus"></i>
                                        <span>Gelen İstekler</span>
                                    </a>
                                </li>
                            }
                        </ul>
                    </li>

                    <li class="nav-item" style="margin-top: auto !important; padding-bottom: 20px;">
                        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout"
                            asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                            <button type="submit" class="logout-btn"
                                style="width:100%; border:none; background:none; text-align:left; padding:10px 20px; color:white;">
                                <i class="fas fa-sign-out-alt"></i> <span><a href="~/Account/Logout"> Çıkış Yap</a>
                                </span>
                            </button>
                        </form>
                    </li>
                </ul>
            </nav>
        </aside>
        <div class="main-content">
            <header class="main-header">
                <button class="sidebar-toggle">
                    <i class="fas fa-bars"></i>
                </button>
                <div class="header-title">
                    <h1>
                        Hoş Geldiniz,


                        @{

                            var user = UserManager.FindByNameAsync(User.Identity.Name).Result;


                            if (user != null)
                            {
                                @user.FullName.ToUpper()
                                ;
                            }
                            else
                            {
                                @:"Misafir"
                            }

                        }





                    </h1>
                </div>
            </header>

            <main class="page-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function () {
            $('.table').not('#projectsTable').each(function () {
                if (!$.fn.DataTable.isDataTable(this)) {
                    $(this).DataTable({
                        "order": [], // 👈 Sunucudan gelen sıralamayı bozma
                        "pageLength": 50,
                        "language": {
                            "decimal": "",
                            "emptyTable": "Tabloda herhangi bir veri mevcut değil",
                            "info": "_TOTAL_ kayıttan _START_ - _END_ arasındaki kayıtlar gösteriliyor",
                            "infoEmpty": "Kayıt yok",
                            "infoFiltered": "(_MAX_ kayıt içerisinden bulunan)",
                            "infoPostFix": "",
                            "thousands": ".",
                            "lengthMenu": "Sayfada _MENU_ kayıt göster",
                            "loadingRecords": "Yükleniyor...",
                            "processing": "İşleniyor...",
                            "search": "Ara:",
                            "zeroRecords": "Eşleşen kayıt bulunamadı",
                            "paginate": {
                                "first": "İlk",
                                "last": "Son",
                                "next": "Sonraki",
                                "previous": "Önceki"
                            },
                            "aria": {
                                "sortAscending": ": artan sütun sıralamasını aktifleştir",
                                "sortDescending": ": azalan sütun sıralamasını aktifleştir"
                            }
                        },
                        "columnDefs": [
                            { "orderable": false, "targets": "no-sort" }
                        ]
                    });
                }
            });
        });
    </script>

    <script>
        document.querySelectorAll('.accordion-menu').forEach(ul => ul.style.display = 'none');
        document.querySelectorAll('.accordion-toggle').forEach(btn => {
            btn.addEventListener('click', function () {
                const menu = btn.nextElementSibling;
                const chevron = btn.querySelector('.bi-chevron-down');
                document.querySelectorAll('.accordion-menu').forEach(ul => { if (ul !== menu) ul.style.display = 'none'; });
                document.querySelectorAll('.accordion-toggle .bi-chevron-down').forEach(icn => { if (icn !== chevron) icn.classList.remove('rotate-chevron'); });

                const isOpen = menu.style.display === 'block';
                menu.style.display = isOpen ? 'none' : 'block';
                chevron.classList.toggle('rotate-chevron', !isOpen);
            });
        });

        // Sidebar Toggle (Mobilde menü açma kapama için eklemen gerekebilir)
        document.querySelector('.sidebar-toggle').addEventListener('click', function () {
            document.getElementById('sidebar').classList.toggle('active');
        });
    </script>

    <script>
        (function() {
            var targets = document.querySelectorAll('.card:not(.modal .card):not(.modal-content), .info-cards > *, .welcome-section, .benefits-section, .table-responsive');
            targets.forEach(function(el) { el.classList.add('anim-reveal'); });
            if ('IntersectionObserver' in window) {
                var observer = new IntersectionObserver(function(entries) {
                    entries.forEach(function(entry) {
                        if (entry.isIntersecting) { entry.target.classList.add('revealed'); observer.unobserve(entry.target); }
                    });
                }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
                targets.forEach(function(el) { observer.observe(el); });
            } else { targets.forEach(function(el) { el.classList.add('revealed'); }); }
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>