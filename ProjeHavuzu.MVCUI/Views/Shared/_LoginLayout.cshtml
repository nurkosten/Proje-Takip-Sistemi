<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Proje Havuz Sistemi</title>

    <link href="~/images/oik_favicon.png" rel="icon" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/home.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        /* Template'den gelen özel stiller */
        body { line-height: 1.6 !important; }
        .sidebar-logo { max-width: 100px !important; margin-bottom: 1.5rem !important; }
        .sidebar-header { padding: 1.5rem !important; text-align: center !important; border-bottom: 1px solid rgba(255, 255, 255, 0.1) !important; background-color: rgba(0, 0, 0, 0.1) !important; }
        h3 { display: block !important; font-size: 1.17rem !important; font-weight: bold !important; }
        .text-muted { color: white !important; }
        .rotate-chevron { transform: rotate(180deg); transition: transform 0.2s; }
    </style>
</head>
<body>
   <header>
            </header>

            <main class="page-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>

    <script>
        document.querySelectorAll('.accordion-menu').forEach(ul => ul.style.display = 'none');
        document.querySelectorAll('.accordion-toggle').forEach(btn => {
            btn.addEventListener('click', function () {
                const menu = btn.nextElementSibling;
                const chevron = btn.querySelector('.bi-chevron-down');
                document.querySelectorAll('.accordion-menu').forEach(ul => { if (ul !== menu) ul.style.display = 'none'; });
                document.querySelectorAll('.accordion-toggle .bi-chevron-down').forEach(icn => { if (icn !== chevron) icn.classList.remove('rotate-chevron'); });

                const isOpen = menu.style.display === 'block';
                menu.style.display = isOpen ? 'none' : 'block';
                chevron.classList.toggle('rotate-chevron', !isOpen);
            });
        });

        // Sidebar Toggle (Mobilde menü açma kapama için eklemen gerekebilir)
        document.querySelector('.sidebar-toggle').addEventListener('click', function() {
            document.getElementById('sidebar').classList.toggle('active');
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>