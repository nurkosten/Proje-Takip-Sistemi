@model List<ProjeHavuzu.Data.Entites.Identity.AppUser>

@{
    ViewData["Title"] = "Kullanıcı Listesi - Log Görüntüleme";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid">
    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
            <h6 class="m-0 font-weight-bold text-primary">Kullanıcı Listesi (Logları Görmek İçin Seçiniz)</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-striped" id="userTable" width="100%" cellspacing="0">
                    <thead class="thead-light">
                        <tr>
                            <th>Ad Soyad</th>
                            <th>Email</th>
                            <th>Telefon</th>
                            <th>Fakülte/Bölüm</th>
                            <th>İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td>@user.FirstName @user.LastName</td>
                                <td>@user.Email</td>
                                <td>@user.PhoneNumber</td>
                                <td>
                                    <!-- Fakülte/Bölüm bilgisi için entity include gerekebilir, şu an boş gelirse service'de include yaparız -->
                                    <!-- Ama UserManager Users genellikle include yapmaz default olarak. Şimdilik sadece adını gösterelim ya da boş geçelim -->
                                    <span class="badge badge-info text-dark">Detayda</span>
                                </td>
                                <td>
                                    <a asp-action="UserLogs" asp-route-userId="@user.Id" class="btn btn-primary btn-sm">
                                        <i class="fas fa-history"></i> Logları Gör
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
}
