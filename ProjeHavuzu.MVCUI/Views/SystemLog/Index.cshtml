@model List<ProjeHavuzu.Data.DTOs.SystemLogDto.SystemLogListDto>

@{
    ViewData["Title"] = "Sistem Logları";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid">
    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
            <h6 class="m-0 font-weight-bold text-primary">Sistem Logları</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-sm" id="dataTable" width="100%" cellspacing="0">
                    <thead class="thead-light">
                        <tr>
                            <th style="width: 140px;">Tarih/Saat</th>
                            <th>IP Adresi</th>
                            <th>Tarayıcı</th>
                            <th>Controller</th>
                            <th>Action</th>
                            <th>Metod</th>
                            <th>URL</th>
                            <th>Kullanıcı</th>
                            <th>Detay</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="@(item.LogType == "Error" ? "table-danger" : (item.LogType == "Warning" ? "table-warning" : ""))">
                                <td data-order="@item.CreatedDate.Ticks">@item.CreatedDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</td>
                                <td>@item.IpAddress</td>
                                <td title="@item.UserAgent">
                                    @{
                                        // Basit browser parse işlemi (Görsel temizlik için)
                                        string browser = "Bilinmiyor";
                                        if(!string.IsNullOrEmpty(item.UserAgent))
                                        {
                                            if (item.UserAgent.Contains("Chrome")) { browser = "Chrome"; }
                                            else if (item.UserAgent.Contains("Firefox")) { browser = "Firefox"; }
                                            else if (item.UserAgent.Contains("Edg")) { browser = "Edge"; }
                                            else if (item.UserAgent.Contains("Safari")) { browser = "Safari"; }
                                            else { browser = "Diğer"; }
                                        }
                                        <span>@browser</span>
                                    }
                                </td>
                                <td>@item.Controller</td>
                                <td>@item.Action</td>
                                <td>@item.HttpMethod</td>
                                <td style="max-width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@item.Url">
                                    <a href="@item.Url" target="_blank">Link</a>
                                </td>
                                <td>@item.CreatedByUserName</td>
                                <td>@item.Detail</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var table = $('#dataTable').DataTable();
            // Varsayılan sıralamayı Tarih sütununa (index 0) göre azalan (desc) yap
            table.order([0, 'desc']).draw();
        });
    </script>
}
