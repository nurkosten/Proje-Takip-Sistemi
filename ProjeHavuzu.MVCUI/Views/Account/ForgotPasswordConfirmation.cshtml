@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Email Gönderildi";
}

<div class="auth-container">
    <!-- Sol Panel: İllüstrasyon + Branding -->
    <div class="auth-left">
        <img src="~/images/auth-illustration.png" alt="Proje Takip" class="auth-left-illustration" />
        <img src="~/images/mtu-logo.png" alt="MTU Logo" class="auth-left-logo" />
        <h2 class="auth-left-title">Proje Takip Sistemi</h2>
        <p class="auth-left-subtitle">Geleceği Birlikte İnşa Ediyoruz</p>
    </div>

    <!-- Sağ Panel: Onay Mesajı -->
    <div class="auth-right" style="text-align: center;">

        <div style="margin-bottom: 1.5rem;">
            <div style="display: inline-flex; align-items: center; justify-content: center; width: 80px; height: 80px;
                        background: rgba(59, 130, 246, 0.1); border-radius: 50%;">
                <i class="bi bi-envelope-check" style="font-size: 2.5rem; color: #3b82f6;"></i>
            </div>
        </div>

        <h3 class="auth-right-title" style="text-align: center;">Lütfen Mail Kutunuzu Kontrol Ediniz</h3>

        <p class="auth-right-desc" style="text-align: center;">
            Şifre sıfırlama talimatlarını içeren bir e-postayı adresinize gönderdik.
            Lütfen gelen kutunuzu (ve spam klasörünü) kontrol ediniz.
        </p>

        <a asp-action="Login" asp-controller="Account" class="btn-auth-primary" style="text-decoration: none;">
            <i class="bi bi-arrow-left me-2"></i> Giriş Ekranına Dön
        </a>

    </div>
</div>
