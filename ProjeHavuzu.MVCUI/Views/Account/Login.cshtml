@model LoginViewModel

@{
    ViewData["Title"] = "Giriş Yap";
    Layout = "_LoginLayout";
}

<div class="auth-container">
    <!-- Sol Panel: İllüstrasyon + Branding -->
    <div class="auth-left">
        <img src="~/images/auth-illustration.png" alt="Proje Takip" class="auth-left-illustration" />
        <img src="~/images/mtu-logo.png" alt="MTU Logo" class="auth-left-logo" />
        <h2 class="auth-left-title">Proje Takip Sistemi</h2>
        <p class="auth-left-subtitle">Geleceği Birlikte İnşa Ediyoruz</p>
    </div>

    <!-- Sağ Panel: Giriş Formu -->
    <div class="auth-right">
        <h3 class="auth-right-title">Giriş Yap</h3>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-circle-fill me-2"></i> @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        <form asp-action="Login" method="post" class="auth-form">

            <div class="mb-3">
                <label asp-for="Email" class="form-label">E-posta</label>
                <input asp-for="Email" class="form-control" placeholder="hesabx@ozal.edu.tr" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">Şifre</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Parolayı girin..." />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label">Beni Hatırla</label>
                </div>
            </div>

            <button type="submit" class="btn-auth-primary">
                Giriş Yap
            </button>

            <div class="auth-footer-text" style="margin-top: 0.75rem;">
                <a asp-controller="Account" asp-action="ForgotPassword" class="auth-forgot-link">Şifremi Unuttum?</a>
            </div>

            <div class="auth-footer-text">
                Öğrenci misiniz? <a asp-action="Register">Öğrenci Kayıt</a>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
