@using ProjeHavuzu.MVCUI.Models.AccountModels
@model ResetPasswordViewModel
@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Şifre Sıfırlama";
}

<div class="auth-container">
    <!-- Sol Panel: İllüstrasyon + Branding -->
    <div class="auth-left">
        <img src="~/images/auth-illustration.png" alt="Proje Takip" class="auth-left-illustration" />
        <img src="~/images/mtu-logo.png" alt="MTU Logo" class="auth-left-logo" />
        <h2 class="auth-left-title">Proje Takip Sistemi</h2>
        <p class="auth-left-subtitle">Geleceği Birlikte İnşa Ediyoruz</p>
    </div>

    <!-- Sağ Panel: Yeni Şifre Formu -->
    <div class="auth-right">
        <h3 class="auth-right-title">Yeni Şifre Belirle</h3>

        <form asp-action="ResetPassword" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="Token" />

            <div class="mb-3">
                <label asp-for="Password" class="form-label">Yeni Şifre</label>
                <input asp-for="Password" class="form-control" type="password" placeholder="Yeni Şifre"
                    id="newPassword" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label">Yeni Şifre Tekrar</label>
                <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Yeni Şifre Tekrar" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <!-- Şifre Gereksinimleri -->
            <ul class="password-requirements">
                <li class="req-title">Şifre gereksinimleri:</li>
                <li><span class="req-icon">✓</span> En az 8 karakter</li>
                <li><span class="req-icon">✓</span> En az 1 sayı</li>
            </ul>

            <!-- Şifre Güç Barı -->
            <div class="password-strength-bar" id="strengthBar">
                <div class="strength-segment active-red"></div>
                <div class="strength-segment active-orange"></div>
                <div class="strength-segment active-yellow"></div>
                <div class="strength-segment active-lime"></div>
                <div class="strength-segment active-green"></div>
                <div class="strength-segment active-emerald"></div>
            </div>

            <button type="submit" class="btn-auth-orange" style="margin-top: 1rem;">
                Şifreyi Güncelle
            </button>

            <div class="auth-footer-text">
                <a asp-action="Login" asp-controller="Account">Giriş Yap</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Şifre güç barı dinamik güncelleme
        document.getElementById('newPassword')?.addEventListener('input', function () {
            const val = this.value;
            const segments = document.querySelectorAll('#strengthBar .strength-segment');
            let score = 0;

            if (val.length >= 4) score++;
            if (val.length >= 8) score++;
            if (/[a-z]/.test(val) && /[A-Z]/.test(val)) score++;
            if (/\d/.test(val)) score++;
            if (/[^a-zA-Z0-9]/.test(val)) score++;
            if (val.length >= 12) score++;

            segments.forEach((seg, i) => {
                if (i < score) {
                    seg.style.opacity = '1';
                } else {
                    seg.style.opacity = '0.25';
                }
            });
        });

        // Başlangıçta tüm segment'leri soluk yap
        document.querySelectorAll('#strengthBar .strength-segment').forEach(seg => {
            seg.style.opacity = '0.25';
        });
    </script>
}
