@model ForgotPasswordViewModel
@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Şifremi Unuttum";
}

<div class="auth-container">
    <!-- Sol Panel: İllüstrasyon + Branding -->
    <div class="auth-left">
        <img src="~/images/auth-illustration.png" alt="Proje Takip" class="auth-left-illustration" />
        <img src="~/images/mtu-logo.png" alt="MTU Logo" class="auth-left-logo" />
        <h2 class="auth-left-title">Proje Takip Sistemi</h2>
        <p class="auth-left-subtitle">Geleceği Birlikte İnşa Ediyoruz</p>
    </div>

    <!-- Sağ Panel: Şifre Sıfırlama Formu -->
    <div class="auth-right">
        <h3 class="auth-right-title">Şifremi Unuttum</h3>
        <p class="auth-right-desc">
            Şifre sıfırlama bağlantısını gönderebilmemiz
            için e-posta adrestizi girin.
        </p>

        <form asp-action="ForgotPassword" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-4">
                <label asp-for="Email" class="form-label">E-posta</label>
                <input asp-for="Email" class="form-control" placeholder="ornek@ozal.edu.tr" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-auth-orange">
                Sıfırlama Bağlantısı Gönder
            </button>

            <a asp-action="Login" asp-controller="Account" class="auth-back-link">
                ← Giriş Yap'a Dön
            </a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
