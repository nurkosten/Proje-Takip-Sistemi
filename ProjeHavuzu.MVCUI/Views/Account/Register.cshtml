@using ProjeHavuzu.Data.Entites.Enums
@using ProjeHavuzu.Data.Entites.Identity
@using ProjeHavuzu.MVCUI.Models.AccountModels
@model RegisterViewModel
@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Kayưt Ol";
}

<div class="auth-container">
    <!-- Sol Panel: Ưllüstrasyon + Branding -->
    <div class="auth-left">
        <img src="~/images/auth-illustration.png" alt="Proje Takip" class="auth-left-illustration" />
        <img src="~/images/mtu-logo.png" alt="MTU Logo" class="auth-left-logo" />
        <h2 class="auth-left-title">Proje Takip Sistemi</h2>
        <p class="auth-left-subtitle">Geleceđi Birlikte Ưn₫a Ediyoruz</p>
    </div>

    <!-- Sađ Panel: Kayưt Formu -->
    <div class="auth-right">
        <h3 class="auth-right-title">Öđrenci Kayưt</h3>
        <p class="text-muted small mb-3">Bu sayfa yalnưzca <strong>öđrenciler</strong> içindir. Akademisyen hesaplarư sistem yöneticisi tarafưndan olu₫turulur.</p>

        <form asp-action="Register" asp-controller="Account" method="post" class="auth-form">

            <div class="row mb-3">
                <div class="col-6">
                    <label asp-for="FirstName" class="form-label">Ad</label>
                    <input asp-for="FirstName" class="form-control" placeholder="Ad" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>
                <div class="col-6">
                    <label asp-for="LastName" class="form-label">Soyad</label>
                    <input asp-for="LastName" class="form-control" placeholder="Soyad" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="StudentNumber" class="form-label">Öđrenci Numarasư</label>
                <input asp-for="StudentNumber" class="form-control" placeholder="Örn: 202412345" />
                <span asp-validation-for="StudentNumber" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Kurumsal E-posta</label>
                <input asp-for="Email" class="form-control" placeholder="ogrencino@ozal.edu.tr" />
                <div class="form-check mt-2">
                    <input class="form-check-input" type="checkbox" id="emailInfoCheck" checked disabled />
                    <label class="form-check-label" for="emailInfoCheck" style="font-size: 0.78rem; color: #6b7c93;">
                        Sadece <strong>@@ozal.edu.tr</strong> uzantưlư okul mailinizle kayưt olabilirsiniz.
                    </label>
                </div>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">̃ifre</label>
                <input asp-for="Password" type="password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label">̃ifre Tekrar</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" />
                <div class="form-check mt-2">
                    <input class="form-check-input" type="checkbox" id="pwInfoCheck" checked disabled />
                    <label class="form-check-label" for="pwInfoCheck" style="font-size: 0.78rem; color: #6b7c93;">
                        ̃ifre en az 8 karakter uzunluđunda, sayư ve özel karakter içermelidir.
                    </label>
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-auth-primary">
                Kayưt Ol
            </button>

            <div class="auth-footer-text">
                Hesabưn var mư? <a asp-action="Login">Giri₫ Yap</a>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
