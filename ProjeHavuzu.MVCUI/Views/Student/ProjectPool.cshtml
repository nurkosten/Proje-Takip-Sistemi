@{
    ViewData["Title"] = "Proje Havuzu";
    var pendingRequestProjectIds = ViewBag.PendingRequestProjectIds as List<Guid> ?? new List<Guid>();
}

<div style="display:none;">
    @Html.AntiForgeryToken()
</div>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-collection"></i> Proje Havuzu</h3>
        <div>
            <a asp-action="MyRequests" class="btn btn-info me-2">
                <i class="bi bi-inbox"></i> İsteklerim
            </a>
            <a asp-action="Index" asp-controller="Home" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Ana Sayfaya Dön
            </a>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table id="projectsTable" class="table table-striped table-hover table-bordered" style="width:100%">
                    <thead class="table-dark">
                        <tr>
                            <th>Proje Adı</th>
                            <th>Kategori</th>
                            <th>Zorluk</th>
                            <th>İlerleme</th>
                            <th style="width: 25%;">Açıklama</th>
                            <th>Danışman</th>
                            <th>Bitiş Tarihi</th>
                            <th class="text-center no-sort" style="width: 180px;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @* Server-side: Veriler AJAX ile doldurulacak *@
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- SweetAlert2 CDN -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // Pending request project IDs from server
        var pendingIds = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(pendingRequestProjectIds));

        $(document).ready(function () {
            $('#projectsTable').DataTable({
                "processing": true,
                "serverSide": true,
                "ajax": {
                    "url": "@Url.Action("GetProjectsData", "Student")",
                    "type": "POST",
                    "error": function (xhr, error, thrown) {
                        console.error('DataTables AJAX error:', error, thrown);
                    }
                },
                "order": [[0, "asc"]],
                "pageLength": 50,
                "lengthMenu": [10, 25, 50, 100, 250],
                "columns": [
                    { "data": "projectTitle", "className": "fw-bold" },
                    {
                        "data": "categoryName",
                        "render": function (data) {
                            return '<span class="badge bg-info">' + data + '</span>';
                        }
                    },
                    {
                        "data": "difficultyLevel",
                        "render": function (data) {
                            switch (data) {
                                case "Easy": case "Kolay":
                                    return '<span class="badge bg-success">Kolay</span>';
                                case "Medium": case "Orta":
                                    return '<span class="badge bg-warning text-dark">Orta</span>';
                                case "Hard": case "Zor":
                                    return '<span class="badge bg-danger">Zor</span>';
                                default:
                                    return '<span class="badge bg-secondary">' + data + '</span>';
                            }
                        }
                    },
                    {
                        "data": "completionPercentage",
                        "render": function (data) {
                            var color = data < 30 ? "bg-danger" : data < 70 ? "bg-warning" : "bg-success";
                            return '<div class="d-flex align-items-center">' +
                                '<div class="progress flex-grow-1" style="height: 8px; min-width: 60px;">' +
                                '<div class="progress-bar ' + color + '" role="progressbar" style="width: ' + data + '%;" aria-valuenow="' + data + '" aria-valuemin="0" aria-valuemax="100"></div>' +
                                '</div>' +
                                '<span class="badge ' + color + ' ms-2">%' + data + '</span>' +
                                '</div>';
                        }
                    },
                    { "data": "description" },
                    {
                        "data": "consultantFullName",
                        "render": function (data) {
                            if (!data || data === 'Danışman Atanmadı') {
                                return '<span class="text-muted"><i class="bi bi-person-x"></i> Danışman Atanmadı</span>';
                            }
                            return '<i class="bi bi-person-badge"></i> ' + data;
                        }
                    },
                    { "data": "endDate" },
                    {
                        "data": "id",
                        "orderable": false,
                        "searchable": false,
                        "className": "text-center",
                        "render": function (data, type, row) {
                            var hasPending = pendingIds.indexOf(data) > -1;
                            var html = '<div class="btn-group" role="group">' +
                                '<a href="/Student/ProjectDetails/' + data + '?returnUrl=' + encodeURIComponent('/Student/ProjectPool') + '" class="btn btn-primary btn-sm" title="Detay"><i class="bi bi-eye"></i></a>';

                            if (hasPending) {
                                html += '<button type="button" class="btn btn-secondary btn-sm" disabled title="İstek Gönderildi"><i class="bi bi-clock-history"></i> Beklemede</button>';
                            } else {
                                html += '<button type="button" class="btn btn-success btn-sm btn-request-modal" data-id="' + data + '" data-title="' + row.projectTitle.replace(/"/g, '&quot;') + '" title="Katılım İsteği Gönder"><i class="bi bi-send"></i> İstek</button>';
                            }
                            html += '</div>';
                            return html;
                        }
                    }
                ],
                "language": {
                    "decimal": "",
                    "emptyTable": "Tabloda herhangi bir veri mevcut değil",
                    "info": "_TOTAL_ kayıttan _START_ - _END_ arasındaki kayıtlar gösteriliyor",
                    "infoEmpty": "Kayıt yok",
                    "infoFiltered": "(_MAX_ kayıt içerisinden bulunan)",
                    "infoPostFix": "",
                    "thousands": ".",
                    "lengthMenu": "Sayfada _MENU_ kayıt göster",
                    "loadingRecords": "Yükleniyor...",
                    "processing": '<div class="d-flex justify-content-center align-items-center"><div class="spinner-border text-primary me-2" role="status"></div> İşleniyor...</div>',
                    "search": "Ara:",
                    "zeroRecords": "Eşleşen kayıt bulunamadı",
                    "paginate": {
                        "first": "İlk",
                        "last": "Son",
                        "next": "Sonraki",
                        "previous": "Önceki"
                    },
                    "aria": {
                        "sortAscending": ": artan sütun sıralamasını aktifleştir",
                        "sortDescending": ": azalan sütun sıralamasını aktifleştir"
                    }
                }
            });

            // SweetAlert2 ile istek gönderme (delegasyon ile DataTables sayfalandırma sonrası da çalışır)
            $(document).on('click', '.btn-request-modal', function () {
                var projectId = $(this).attr('data-id');
                var projectTitle = $(this).attr('data-title');

                Swal.fire({
                    title: 'Proje Katılım İsteği',
                    html: `<strong>${projectTitle}</strong> projesine katılım isteği göndermek istediğinize emin misiniz?`,
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#198754',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Evet, İstek Gönder',
                    cancelButtonText: 'İptal',
                    showLoaderOnConfirm: true,
                    preConfirm: () => {
                        var token = $('input[name="__RequestVerificationToken"]').val();
                        if (!token) {
                            Swal.showValidationMessage('Güvenlik doğrulaması (Token) bulunamadı. Sayfayı yenileyip tekrar deneyin.');
                            return false;
                        }

                        return $.ajax({
                            url: '/Student/SendProjectRequest',
                            type: 'POST',
                            headers: { "X-Requested-With": "XMLHttpRequest" },
                            data: {
                                projectId: projectId,
                                message: '',
                                __RequestVerificationToken: token
                            }
                        }).then(response => {
                            if (!response.success) {
                                throw new Error(response.message || 'Sunucu hatası oluştu.');
                            }
                            return response;
                        }).catch(xhr => {
                            var errorMsg = 'Bir hata oluştu.';
                            if (xhr.responseJSON && xhr.responseJSON.message) {
                                errorMsg = xhr.responseJSON.message;
                            } else if (xhr.responseText) {
                                errorMsg = 'Sunucuyla iletişim kurulurken bir hata oluştu (HTTP ' + xhr.status + ')';
                            }
                            Swal.showValidationMessage(errorMsg);
                        });
                    },
                    allowOutsideClick: () => !Swal.isLoading()
                }).then((result) => {
                    if (result.isConfirmed && result.value && result.value.success) {
                        Swal.fire({
                            title: 'Başarılı!',
                            text: result.value.message || 'İsteğiniz başarıyla iletildi.',
                            icon: 'success',
                            confirmButtonColor: '#198754'
                        }).then(() => {
                            location.reload();
                        });
                    }
                });
            });
        });
    </script>
}
