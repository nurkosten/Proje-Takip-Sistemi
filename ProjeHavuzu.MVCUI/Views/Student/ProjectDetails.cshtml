@using ProjeHavuzu.Data.DTOs.ProjectDto
@model ProjectDetailDto

@{
    ViewData["Title"] = "Proje Detayları";
    var returnUrl = ViewBag.ReturnUrl as string ?? Url.Action("ProjectPool", "Student");
    ViewData["EnablePhaseToggle"] = false;
    ViewData["ShowStudentsSection"] = false;
}

<link rel="stylesheet" href="~/css/project-details.css" asp-append-version="true" />

<div class="project-details-page container-fluid px-4 mb-5">
    <div class="details-header">
        <div class="row align-items-start g-3">
            <div class="col-lg-7">
                <h1 class="details-title">
                    <i class="bi bi-folder2-open"></i> Proje Detayları
                </h1>
                <p class="details-description">
                    Seçilen projeye ait temel bilgiler, danışman bilgileri ve proje durumu aşağıda listelenmiştir.
                </p>
            </div>
            <div class="col-lg-5">
                <div class="details-actions">
                    <a href="@returnUrl" class="btn btn-details-outline">
                        <i class="bi bi-arrow-left me-1"></i> Geri Dön
                    </a>
                    <a asp-controller="Student" asp-action="MyProjects" class="btn btn-details-primary">
                        <i class="bi bi-folder-check me-1"></i> Projelerime Git
                    </a>
                </div>
            </div>
        </div>
    </div>

    @await Html.PartialAsync("_ProjectDetailsContent", Model)
</div>
