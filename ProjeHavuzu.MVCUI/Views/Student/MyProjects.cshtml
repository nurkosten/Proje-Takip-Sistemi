@using ProjeHavuzu.Data.DTOs.ProjectStudentDto
@using ProjeHavuzu.Data.Entites.Enums
@model List<ProjectStudentAssignDto>

@{
    ViewData["Title"] = "Projelerim & Durum";
}

<div class="container-fluid mt-4 px-4">
    <!-- Sayfa Başlığı -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0 fw-bold" style="color: #003366;">
            <i class="bi bi-folder-check me-2"></i>Projelerim &amp; Durum
        </h3>
        <a asp-action="Index" asp-controller="Home" class="btn btn-outline-dark rounded-pill px-4">
            <i class="bi bi-arrow-left me-1"></i> Ana Sayfaya Dön
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert" style="border-left: 4px solid #059669 !important;">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm" role="alert" style="border-left: 4px solid #dc2626 !important;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Proje Kartı -->
    <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
        <div class="card-header py-3" style="background: linear-gradient(135deg, #003366 0%, #004080 100%);">
            <h5 class="mb-0 text-white fw-bold">
                <i class="bi bi-list-task me-2"></i>Atanan Projelerim
                <span class="badge bg-white text-dark rounded-pill ms-2 fw-semibold" style="font-size: .75rem;">@(Model?.Count ?? 0)</span>
            </h5>
        </div>
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr style="background: #f8fafc; border-bottom: 2px solid #e5e9f0;">
                                <th class="ps-4 py-3" style="color: #475569; font-weight: 600; font-size: .8rem; text-transform: uppercase; letter-spacing: .05em;">Proje Adı</th>
                                <th class="py-3" style="color: #475569; font-weight: 600; font-size: .8rem; text-transform: uppercase; letter-spacing: .05em;">Kategori</th>
                                <th class="py-3" style="color: #475569; font-weight: 600; font-size: .8rem; text-transform: uppercase; letter-spacing: .05em;">Danışman</th>
                                <th class="py-3" style="color: #475569; font-weight: 600; font-size: .8rem; text-transform: uppercase; letter-spacing: .05em;">Onay Durumu</th>
                                <th class="py-3" style="color: #475569; font-weight: 600; font-size: .8rem; text-transform: uppercase; letter-spacing: .05em;">İlerleme</th>
                                <th class="py-3 text-center" style="color: #475569; font-weight: 600; font-size: .8rem; text-transform: uppercase; letter-spacing: .05em;">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr style="border-bottom: 1px solid #f1f3f7;">
                                    <td class="ps-4 py-3">
                                        <div class="d-flex align-items-center">
                                            <div class="me-3" style="width: 36px; height: 36px; background: linear-gradient(135deg, #003366, #336699); border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                                                <i class="bi bi-folder2-open text-white" style="font-size: .9rem;"></i>
                                            </div>
                                            <strong style="color: #1e293b;">@item.ProjectTitle</strong>
                                        </div>
                                    </td>
                                    <td class="py-3" style="color: #64748b; font-size: .84rem;">@(item.CategoryName ?? "-")</td>
                                    <td class="py-3" style="color: #64748b; font-size: .84rem;">@(item.ConsultantFullName ?? "-")</td>
                                    <td class="py-3">
                                        @switch (item.ApprovalStatus)
                                        {
                                            case ProjectApprovalStatus.Pending:
                                                <span class="badge rounded-pill" style="background: #fef3c7; color: #92400e;">Danışman Onayı Bekliyor</span>
                                                break;
                                            case ProjectApprovalStatus.Approved:
                                                <span class="badge rounded-pill" style="background: #d1fae5; color: #065f46;">Onaylandı</span>
                                                break;
                                            case ProjectApprovalStatus.Rejected:
                                                <span class="badge rounded-pill" style="background: #fee2e2; color: #991b1b;">Reddedildi</span>
                                                @if (!string.IsNullOrWhiteSpace(item.RejectionReason))
                                                {
                                                    <div class="small text-muted mt-1">Red Sebebi: @item.RejectionReason</div>
                                                }
                                                break;
                                        }
                                    </td>
                                    <td class="py-3">
                                        @{
                                            var pct = item.CompletionPercentage;
                                            var progressColor = pct < 30 ? "bg-danger" : pct < 70 ? "bg-warning" : "bg-success";
                                            var progressGradient = pct < 30 ? "linear-gradient(90deg, #dc2626, #ef4444)" :
                                                                   pct < 70 ? "linear-gradient(90deg, #d97706, #f59e0b)" :
                                                                              "linear-gradient(90deg, #059669, #10b981)";
                                        }
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="progress flex-grow-1" style="height: 8px; min-width: 80px; background: #f1f5f9; border-radius: 6px;">
                                                <div class="progress-bar" role="progressbar"
                                                     style="width: @pct%; background: @progressGradient; border-radius: 6px;"
                                                     aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100"></div>
                                            </div>
                                            <span class="badge rounded-pill fw-semibold" style="background: @progressGradient; min-width: 42px; font-size: .72rem;">%@pct</span>
                                        </div>
                                    </td>
                                    <td class="py-3 text-center">
                                        <div class="btn-group" role="group">
                                            <a asp-action="ProjectDetails" asp-route-id="@item.ProjectId"
                                               class="btn btn-sm btn-primary" title="Detay"
                                               style="background: #003366; border-color: #003366; border-radius: 6px 0 0 6px;">
                                                <i class="bi bi-eye me-1"></i> Detay
                                            </a>
                                            <a asp-controller="Project" asp-action="Edit" asp-route-id="@item.ProjectId"
                                               class="btn btn-sm btn-outline-secondary" title="Düzenle"
                                               style="border-radius: 0 6px 6px 0;">
                                                <i class="bi bi-pencil me-1"></i> Düzenle
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5 px-4">
                    <div class="mb-3" style="width: 64px; height: 64px; background: linear-gradient(135deg, #e8f0fe, #dbeafe); border-radius: 50%; display: inline-flex; align-items: center; justify-content: center;">
                        <i class="bi bi-folder-x" style="font-size: 1.5rem; color: #003366;"></i>
                    </div>
                    <h5 class="mt-2 fw-semibold" style="color: #1e293b;">Henüz size atanmış proje bulunmuyor</h5>
                    <p class="mb-3" style="color: #94a3b8; font-size: .9rem;">Akademisyenler tarafından proje atandığında burada görüntülenecektir.</p>
                    <a asp-action="ProjectPool" class="btn btn-primary px-4 rounded-pill" style="background: linear-gradient(135deg, #003366, #004080); border: none;">
                        <i class="bi bi-search me-1"></i> Proje Havuzunu İncele
                    </a>
                </div>
            }
        </div>
    </div>
</div>
