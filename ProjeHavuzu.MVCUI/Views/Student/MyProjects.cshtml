@using ProjeHavuzu.Data.DTOs.ProjectStudentDto
@model List<ProjectStudentAssignDto>

@{
    ViewData["Title"] = "Projelerim & Durum";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-folder-check"></i> Projelerim & Durum</h3>
        <a asp-action="Index" asp-controller="Home" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Ana Sayfaya Dön
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-list-task"></i> Atanan Projelerim</h5>
        </div>
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover table-striped table-bordered">
                        <thead class="table-dark">
                            <tr>
                                <th>Proje Adı</th>
                                <th style="width: 35%;">Açıklama</th>
                                <th>% Durum</th>
                                <th>Detay</th>
                                <th>Düzenleme</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>@item.ProjectTitle</strong>
                                    </td>
                                    <td>
                                        @(string.IsNullOrEmpty(item.Description) ? "-" : 
                                            (item.Description.Length > 80 ? item.Description.Substring(0, 80) + "..." : item.Description))
                                    </td>
                                    <td>
                                        @{
                                            var progressColor = item.CompletionPercentage < 30 ? "bg-danger" : 
                                                                item.CompletionPercentage < 70 ? "bg-warning" : "bg-success";
                                        }
                                        <div class="d-flex align-items-center">
                                            <div class="progress flex-grow-1" style="height: 8px; min-width: 60px;">
                                                <div class="progress-bar @progressColor" role="progressbar" style="width: @item.CompletionPercentage%;" aria-valuenow="@item.CompletionPercentage" aria-valuemin="0" aria-valuemax="100"></div>
                                            </div>
                                            <span class="badge @progressColor ms-2">%@item.CompletionPercentage</span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <a asp-action="ProjectDetails" asp-route-id="@item.ProjectId" class="btn btn-sm btn-info" title="Detay">
                                            <i class="bi bi-eye"></i> Detay
                                        </a>
                                    </td>
                                    <td class="text-center">
                                        <a asp-controller="Project" asp-action="Edit" asp-route-id="@item.ProjectId" class="btn btn-sm btn-warning" title="Düzenle">
                                            <i class="bi bi-pencil"></i> Düzenle
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info text-center">
                    <i class="bi bi-info-circle fs-1"></i>
                    <h5 class="mt-3">Henüz size atanmış proje bulunmuyor.</h5>
                    <p>Akademisyenler tarafından proje atandığında burada görüntülenecektir.</p>
                    <a asp-action="ProjectPool" class="btn btn-primary mt-2">
                        <i class="bi bi-search"></i> Proje Havuzunu İncele
                    </a>
                </div>
            }
        </div>
    </div>
</div>
