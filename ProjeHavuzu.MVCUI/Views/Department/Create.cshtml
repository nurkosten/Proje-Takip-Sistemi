@using ProjeHavuzu.Data.DTOs.DepartmentDto
@using Microsoft.AspNetCore.Mvc.Rendering
@model DepartmentCreateDto

@{
    ViewData["Title"] = "Bölüm Ekle";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow">
                <div class="card-header">
                    <h4 class="mb-0">Bölüm Ekle</h4>
                </div>
                <div class="card-body">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <div>@error.ErrorMessage</div>
                            }
                        </div>
                    }

                    <form asp-action="Create" asp-controller="Department" method="post">
                        <div class="mb-3">
                            <label asp-for="FacultyId" class="form-label">Fakülte</label>
                            <select asp-for="FacultyId" class="form-select" asp-items="@(new SelectList(Model.Faculties, "Id", "FacultyName"))">
                                <option value="">-- Fakülte Seçin --</option>
                            </select>
                            <span asp-validation-for="FacultyId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DepartmentName" class="form-label">Bölüm Adı</label>
                            <input asp-for="DepartmentName" class="form-control" placeholder="Bölüm adını girin" />
                            <span asp-validation-for="DepartmentName" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-check-circle"></i> Kaydet
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-x-circle"></i> İptal
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
