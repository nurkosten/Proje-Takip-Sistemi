@using ProjeHavuzu.Data.Entites
@model List<ProjectRequest>

@{
    ViewData["Title"] = "Proje İstekleri";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid mt-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0 fw-bold" style="color: #003366;">
            <i class="bi bi-inbox-fill me-2"></i>Proje İstekleri
        </h3>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-dark rounded-pill px-4">
            <i class="bi bi-arrow-left me-1"></i> Ana Sayfa
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-header py-3" style="background: linear-gradient(135deg, #003366 0%, #004080 100%);">
            <h5 class="mb-0 text-white fw-bold">
                <i class="bi bi-envelope-paper me-2"></i>Bekleyen İstekler
                <span class="badge bg-white text-dark rounded-pill ms-2">@(Model?.Count ?? 0)</span>
            </h5>
        </div>
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr style="background: #f8fafc;">
                                <th class="ps-4">Öğrenci</th>
                                <th>Proje</th>
                                <th>İstek Tarihi</th>
                                <th>Öğrenci Mesajı</th>
                                <th class="text-center">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var request in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <strong>@request.Student?.FullName</strong><br />
                                        <small class="text-muted">@request.Student?.Email</small>
                                    </td>
                                    <td>@request.Project?.ProjectTitle</td>
                                    <td>@request.RequestDate.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>@(string.IsNullOrEmpty(request.Message) ? "-" : request.Message)</td>
                                    <td class="text-center">
                                        <button type="button" class="btn btn-sm btn-success me-1"
                                                data-bs-toggle="modal" data-bs-target="#approveModal"
                                                data-request-id="@request.Id"
                                                data-student-name="@request.Student?.FullName"
                                                data-project-title="@request.Project?.ProjectTitle">
                                            <i class="bi bi-check-lg"></i> Onayla
                                        </button>
                                        <button type="button" class="btn btn-sm btn-danger"
                                                data-bs-toggle="modal" data-bs-target="#rejectModal"
                                                data-request-id="@request.Id"
                                                data-student-name="@request.Student?.FullName"
                                                data-project-title="@request.Project?.ProjectTitle">
                                            <i class="bi bi-x-lg"></i> Reddet
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">Bekleyen proje isteği bulunmuyor.</div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="approveModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <form asp-controller="Admin" asp-action="ApproveRequest" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="requestId" id="approveRequestId" />
                <input type="hidden" name="returnUrl" value="/Admin/ProjectRequests" />
                <div class="modal-header border-0 py-3" style="background: linear-gradient(135deg, #059669, #10b981);">
                    <h5 class="modal-title text-white fw-bold"><i class="bi bi-check-circle me-2"></i>İsteği Onayla</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <p><strong id="approveStudentName"></strong> — <strong id="approveProjectTitle"></strong></p>
                    <label for="approveMessage" class="form-label">Yanıt (isteğe bağlı)</label>
                    <textarea class="form-control" id="approveMessage" name="responseMessage" rows="3"></textarea>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Vazgeç</button>
                    <button type="submit" class="btn btn-success">Onayla</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="rejectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <form asp-controller="Admin" asp-action="RejectRequest" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="requestId" id="rejectRequestId" />
                <input type="hidden" name="returnUrl" value="/Admin/ProjectRequests" />
                <div class="modal-header border-0 py-3" style="background: linear-gradient(135deg, #dc2626, #ef4444);">
                    <h5 class="modal-title text-white fw-bold"><i class="bi bi-x-circle me-2"></i>İsteği Reddet</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <p><strong id="rejectStudentName"></strong> — <strong id="rejectProjectTitle"></strong></p>
                    <label for="rejectMessage" class="form-label">Reddetme nedeni</label>
                    <textarea class="form-control" id="rejectMessage" name="responseMessage" rows="3" required></textarea>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Vazgeç</button>
                    <button type="submit" class="btn btn-danger">Reddet</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('approveModal').addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            document.getElementById('approveRequestId').value = button.getAttribute('data-request-id');
            document.getElementById('approveStudentName').textContent = button.getAttribute('data-student-name');
            document.getElementById('approveProjectTitle').textContent = button.getAttribute('data-project-title');
        });
        document.getElementById('rejectModal').addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            document.getElementById('rejectRequestId').value = button.getAttribute('data-request-id');
            document.getElementById('rejectStudentName').textContent = button.getAttribute('data-student-name');
            document.getElementById('rejectProjectTitle').textContent = button.getAttribute('data-project-title');
        });
    </script>
}
