@using ProjeHavuzu.Data.DTOs.ProjectDto
@using ProjeHavuzu.Data.Entites.Enums
@model List<ProjectListDto>

@{
    ViewData["Title"] = "Projelerim & Durum";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid mt-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0 fw-bold" style="color: #003366;">
            <i class="bi bi-folder-check me-2"></i>Projelerim &amp; Durum
        </h3>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-dark rounded-pill px-4">
            <i class="bi bi-arrow-left me-1"></i> Ana Sayfa
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-header py-3" style="background: linear-gradient(135deg, #003366 0%, #004080 100%);">
            <h5 class="mb-0 text-white fw-bold">
                <i class="bi bi-list-task me-2"></i>Sistemdeki Tüm Projeler
                <span class="badge bg-white text-dark rounded-pill ms-2">@(Model?.Count ?? 0)</span>
            </h5>
        </div>
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr style="background: #f8fafc;">
                                <th class="ps-4">Proje Adı</th>
                                <th>Kategori</th>
                                <th>Danışman</th>
                                <th>Oluşturan</th>
                                <th>Oluşturulma</th>
                                <th>Onay Durumu</th>
                                <th>İlerleme</th>
                                <th class="text-center">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var project in Model)
                            {
                                <tr>
                                    <td class="ps-4"><strong>@project.ProjectTitle</strong></td>
                                    <td>@project.CategoryName</td>
                                    <td>@(string.IsNullOrWhiteSpace(project.ConsultantFullName) ? "Danışman Atanmadı" : project.ConsultantFullName)</td>
                                    <td>@project.CreatedByFullName</td>
                                    <td>@project.CreatedDate.ToString("dd.MM.yyyy")</td>
                                    <td>
                                        @switch (project.ApprovalStatus)
                                        {
                                            case ProjectApprovalStatus.Pending:
                                                <span class="badge bg-warning text-dark">Onay Bekliyor</span>
                                                break;
                                            case ProjectApprovalStatus.Approved:
                                                <span class="badge bg-success">Onaylandı</span>
                                                break;
                                            case ProjectApprovalStatus.Rejected:
                                                <span class="badge bg-danger">Reddedildi</span>
                                                break;
                                        }
                                    </td>
                                    <td>%@project.CompletionPercentage</td>
                                    <td class="text-center">
                                        <a asp-controller="Project" asp-action="Details" asp-route-id="@project.Id" class="btn btn-sm btn-primary">Detay</a>
                                        <a asp-controller="Project" asp-action="Edit" asp-route-id="@project.Id" asp-route-returnUrl="/Admin/MyProjects" class="btn btn-sm btn-outline-secondary">Düzenle</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">Kayıtlı proje bulunamadı.</div>
            }
        </div>
    </div>
</div>
