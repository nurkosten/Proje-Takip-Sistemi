@using ProjeHavuzu.Data.Entites.Identity
@model IList<AppUser>

@{
    ViewData["Title"] = "Akademisyenler";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-people-fill"></i> Akademisyenler</h3>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover table-striped">
                        <thead class="table-light">
                            <tr>
                                <th>Ad Soyad</th>
                                <th>Kullanıcı Adı</th>
                                <th>E-posta</th>
                                <th>Telefon</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var teacher in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-circle me-2 bg-primary text-white d-flex align-items-center justify-content-center rounded-circle" style="width: 40px; height: 40px;">
                                                @(teacher.FullName?.Length > 0 ? teacher.FullName.Substring(0, 1).ToUpper() : "T")
                                            </div>
                                            <strong>@teacher.FullName</strong>
                                        </div>
                                    </td>
                                    <td>@teacher.UserName</td>
                                    <td>
                                        <a href="mailto:@teacher.Email" class="text-decoration-none">
                                            <i class="bi bi-envelope"></i> @teacher.Email
                                        </a>
                                    </td>
                                    <td>@(teacher.PhoneNumber ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info text-center">
                    <i class="bi bi-info-circle fs-1"></i>
                    <h5 class="mt-3">Sistemde kayıtlı akademisyen bulunmamaktadır.</h5>
                </div>
            }
        </div>
    </div>
</div>
