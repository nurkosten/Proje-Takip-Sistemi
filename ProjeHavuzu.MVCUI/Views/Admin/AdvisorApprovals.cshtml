@using ProjeHavuzu.Data.DTOs.ProjectDto
@using ProjeHavuzu.Data.Entites.Enums
@model List<ProjectListDto>

@{
    ViewData["Title"] = "Danışman Onay";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid mt-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0 fw-bold" style="color: #003366;">
            <i class="bi bi-person-check me-2"></i>Danışman Onay
        </h3>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-dark rounded-pill px-4">
            <i class="bi bi-arrow-left me-1"></i> Ana Sayfa
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-header py-3" style="background: linear-gradient(135deg, #003366 0%, #004080 100%);">
            <h5 class="mb-0 text-white fw-bold">
                <i class="bi bi-hourglass-split me-2"></i>Onay Bekleyen Projeler
                <span class="badge bg-white text-dark rounded-pill ms-2">@(Model?.Count ?? 0)</span>
            </h5>
        </div>
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr style="background: #f8fafc;">
                                <th class="ps-4">Proje Adı</th>
                                <th>Kategori</th>
                                <th>Danışman</th>
                                <th>Oluşturan</th>
                                <th>Oluşturulma</th>
                                <th class="text-center">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var project in Model)
                            {
                                <tr>
                                    <td class="ps-4"><strong>@project.ProjectTitle</strong></td>
                                    <td>@project.CategoryName</td>
                                    <td>@(string.IsNullOrWhiteSpace(project.ConsultantFullName) ? "Atanmadı" : project.ConsultantFullName)</td>
                                    <td>@project.CreatedByFullName</td>
                                    <td>@project.CreatedDate.ToString("dd.MM.yyyy")</td>
                                    <td class="text-center">
                                        <form asp-controller="Admin" asp-action="ApproveProject" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@project.Id" />
                                            <input type="hidden" name="returnUrl" value="/Admin/AdvisorApprovals" />
                                            <button type="submit" class="btn btn-sm btn-success me-1">
                                                <i class="bi bi-check-lg"></i> Onayla
                                            </button>
                                        </form>
                                        <button type="button"
                                                class="btn btn-sm btn-danger"
                                                data-bs-toggle="modal"
                                                data-bs-target="#rejectProjectModal"
                                                data-project-id="@project.Id"
                                                data-project-title="@project.ProjectTitle">
                                            <i class="bi bi-x-lg"></i> Reddet
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">Onay bekleyen proje bulunmuyor.</div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="rejectProjectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <form asp-controller="Admin" asp-action="RejectProject" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="rejectProjectId" />
                <input type="hidden" name="returnUrl" value="/Admin/AdvisorApprovals" />
                <div class="modal-header border-0 py-3" style="background: linear-gradient(135deg, #dc2626, #ef4444);">
                    <h5 class="modal-title text-white fw-bold"><i class="bi bi-x-circle me-2"></i>Projeyi Reddet</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <p class="mb-3"><strong id="rejectProjectTitle"></strong> projesini reddetmek üzeresiniz.</p>
                    <label for="rejectionReason" class="form-label fw-bold">Red Açıklaması <span class="text-danger">*</span></label>
                    <textarea id="rejectionReason" name="rejectionReason" class="form-control" rows="4" required></textarea>
                </div>
                <div class="modal-footer border-0 px-4 pb-4">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-danger">Reddet</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var rejectModal = document.getElementById('rejectProjectModal');
            if (!rejectModal) return;
            rejectModal.addEventListener('show.bs.modal', function (event) {
                var button = event.relatedTarget;
                if (!button) return;
                document.getElementById('rejectProjectId').value = button.getAttribute('data-project-id') || '';
                document.getElementById('rejectProjectTitle').textContent = button.getAttribute('data-project-title') || '';
                document.getElementById('rejectionReason').value = '';
            });
        })();
    </script>
}
