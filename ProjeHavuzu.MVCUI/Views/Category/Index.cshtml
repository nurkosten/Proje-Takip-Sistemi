@using Microsoft.AspNetCore.Identity
@using ProjeHavuzu.Data.DTOs.CategoryDto
@using ProjeHavuzu.Data.Entites.Identity
@model List<CategoryListDto>
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager


@{
    ViewData["Title"] = "Kategori Listesi";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4>Kategori Listesi</h4>
        <a asp-action="Create" asp-controller="Category" class="btn btn-primary">
            + Yeni Kategori
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Kategori Adı</th>
                        <th>Oluşturulma Tarihi</th>
                        <th>Oluşturan</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int index = 1; }
                    @foreach (var item in Model ?? new List<CategoryListDto>())
                    {
                        <tr>
                            <td>@index</td>
                            <td>@item.CategoryName</td>
                            <td>@item.CreatedDate.ToString("dd.MM.yyyy")</td>
                            <td>
                                @{
                                    if (!string.IsNullOrEmpty(item.CreatedBy.ToString()))
                                    {
                                        var user = await UserManager.FindByIdAsync(item.CreatedBy.ToString());
                                        if (user != null)
                                        {
                                            @user.FirstName @user.LastName
                                        }
                                        else
                                        {
                                            @:Bilinmiyor
                                        }
                                    }
                                    else
                                    {
                                        @:Bilinmiyor
                                    }
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-warning me-1">
                                    Düzenle
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-danger">
                                    Sil
                                </a>
                            </td>
                        </tr>
                        index++;
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
