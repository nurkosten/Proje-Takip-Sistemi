@model ProjeHavuzu.Data.Entites.Category

@{
    ViewData["Title"] = "Kategori Sil";
    Layout = "_Layout";
}

<div class="row">
    <div class="col-md-6 offset-md-3">
        <div class="card shadow-sm border-danger">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0"><i class="bi bi-trash"></i> Kategori Sil</h4>
            </div>
            <div class="card-body">
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <strong>Dikkat!</strong> Bu kategoriyi silmek istediğinize emin misiniz?
                </div>

                <dl class="row">
                    <dt class="col-sm-4">Kategori Adı:</dt>
                    <dd class="col-sm-8 fw-bold">@Model.CategoryName</dd>
                    
                    <dt class="col-sm-4">Durum:</dt>
                    <dd class="col-sm-8">
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success">Aktif</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Pasif</span>
                        }
                    </dd>
                </dl>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex justify-content-end mt-4">
                        <a asp-action="Index" class="btn btn-secondary me-2">İptal</a>
                        <button type="submit" class="btn btn-danger">Evet, Sil</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
