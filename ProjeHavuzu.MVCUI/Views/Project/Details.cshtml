@using ProjeHavuzu.Data.DTOs.ProjectDto
@using ProjeHavuzu.Data.Entites.Enums
@model ProjectListDto

@{
    ViewData["Title"] = "Proje Detayı";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-10 offset-md-1">
            <div class="card shadow">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        <i class="bi bi-folder-open"></i> @Model.ProjectTitle
                    </h4>
                    <div>
                        @if (Model.DifficultyLevel == DifficultStatus.Kolay)
                        {
                            <span class="badge bg-success">Kolay</span>
                        }
                        else if (Model.DifficultyLevel == DifficultStatus.Orta)
                        {
                            <span class="badge bg-warning text-dark">Orta</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Zor</span>
                        }
                    </div>
                </div>
                <div class="card-body">
                    <div class="row mb-4">
                        <div class="col-12">
                            <h5 class="text-muted mb-2">Açıklama</h5>
                            <p class="lead">@(string.IsNullOrEmpty(Model.Description) ? "Açıklama bulunmuyor." :
                                Model.Description)</p>
                        </div>
                    </div>

                    <hr />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-tag fs-4 text-primary me-2"></i>
                                <div>
                                    <small class="text-muted d-block">Kategori</small>
                                    <strong>@Model.CategoryName</strong>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-clock fs-4 text-info me-2"></i>
                                <div>
                                    <small class="text-muted d-block">Tarih Aralığı</small>
                                    <strong>@Model.StartDate.ToShortDateString() - @Model.EndDate.ToShortDateString()</strong>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-person fs-4 text-success me-2"></i>
                                <div>
                                    <small class="text-muted d-block">Oluşturan</small>
                                    <strong>@(Model.CreatedByFullName ?? "-")</strong>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-calendar fs-4 text-secondary me-2"></i>
                                <div>
                                    <small class="text-muted d-block">Oluşturulma Tarihi</small>
                                    <strong>@Model.CreatedDate.ToString("dd MMMM yyyy")</strong>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-center">
                                <i
                                    class="bi bi-check-circle fs-4 @(Model.IsActive ? "text-success" : "text-warning") me-2"></i>
                                <div>
                                    <small class="text-muted d-block">Durum</small>
                                    @if (Model.IsActive)
                                    {
                                        <span class="badge bg-success">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Pasif</span>
                                    }
                                </div>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.ProjectLink))
                        {
                            <div class="col-md-6 mb-3">
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-link-45deg fs-4 text-primary me-2"></i>
                                    <div>
                                        <small class="text-muted d-block">Proje Linki</small>
                                        <a href="@Model.ProjectLink" target="_blank" class="fw-bold">Projeyi Görüntüle <i
                                                class="bi bi-box-arrow-up-right"></i></a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="card-footer d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Geri Dön
                    </a>
                    <div>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                            <i class="bi bi-pencil"></i> Düzenle
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
