@using ProjeHavuzu.Data.DTOs.ProjectDto
@model ProjectCreateDto

@{
    ViewData["Title"] = "Proje Ekle";

    var cancelUrl = User.IsInRole("Admin")
        ? Url.Action("MyProjects", "Admin")
        : User.IsInRole("Teacher")
            ? Url.Action("MyProjects", "Teacher")
            : User.IsInRole("Student")
                ? Url.Action("MyProjects", "Student")
                : Url.Action("Index", "Home");

    ViewData["IsEdit"] = false;
    ViewData["FormId"] = "createProjectForm";
    ViewData["FormController"] = "Project";
    ViewData["FormAction"] = "Create";
    ViewData["CancelUrl"] = cancelUrl;
    ViewData["PageTitle"] = "Proje Ekle";
    ViewData["PageDescription"] = "Yeni proje bilgilerini girerek sisteme proje ekleyebilirsiniz.";
    ViewData["SubmitText"] = "Kaydet";
}

@await Html.PartialAsync("_ProjectFormBody", Model)

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @{
        ViewData["FormId"] = "createProjectForm";
        ViewData["IsEdit"] = false;
    }
    @await Html.PartialAsync("_ProjectFormScripts")
}
