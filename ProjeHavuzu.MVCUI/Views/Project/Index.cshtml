@using Microsoft.AspNetCore.Identity
@using ProjeHavuzu.Data.DTOs.ProjectDto
@using ProjeHavuzu.Data.Entites.Identity
@model List<ProjectListDto>
@inject UserManager<AppUser> UserManager

@{
    ViewData["Title"] = "Project List";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Project List</h3>
        <a asp-action="Create" class="btn btn-success">
            + New Project
        </a>
    </div>

    <table class="table table-striped table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Description</th>
                <th>Category</th>
                <th>Difficulty</th>
                <th>Duration (Day)</th>
                <th> Created By</th>
                <th>Link</th>
                <th>İşlemler</th>            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                            <tr>
                                <td>@item.ProjectTitle</td>
                                <td>@item.Description</td>
                                <td>@item.CategoryName</td>
                                <td>@item.DifficultyLevel</td>
                                <td>@item.EndTime</td>
                                <td>

                            @item.CreatedByFullName
                                </td>
                                <td>
                            @if (!string.IsNullOrWhiteSpace(item.ProjectLink))
                            {
                                            <a href="@item.ProjectLink" target="_blank" class="btn btn-sm btn-outline-primary mb-1">
                                                View Link
                                            </a>
                            }
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">
                                        <i class="bi bi-eye"></i> Detay
                                    </a>
                                </td>

                            </tr>
                }
            }
            else
            {
                    <tr>
                        <td colspan="7" class="text-center text-muted">
                            No projects found.
                        </td>
                    </tr>
            }
        </tbody>
    </table>
</div>
