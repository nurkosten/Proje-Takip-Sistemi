@{
    ViewData["Title"] = "Tüm Projeler";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-folder-fill"></i> Tüm Projeler</h3>
        <div>
            <a asp-action="RecycleBin" asp-controller="Project" class="btn btn-warning me-2">
                <i class="bi bi-trash"></i> Çöp Kutusu
            </a>
            <a asp-action="Create" asp-controller="Project" class="btn btn-success">
                <i class="bi bi-plus-lg"></i> Yeni Proje
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="table-responsive">
        <table id="projectsTable" class="table table-striped table-bordered table-hover" style="width:100%">
            <thead class="table-dark">
                <tr>
                    <th>Proje Adı</th>
                    <th>Açıklama</th>
                    <th>Kategori</th>
                    <th>Zorluk</th>
                    <th>İlerleme</th>
                    <th>Bitiş Tarihi</th>
                    <th>Oluşturan</th>
                    <th class="no-sort">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @* Server-side: Veriler AJAX ile doldurulacak *@
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Layout'taki otomatik DataTables init'i bu tablo için devre dışı bırak
            // (id ile özel init yapılacak)
            $('#projectsTable').DataTable({
                "processing": true,
                "serverSide": true,
                "ajax": {
                    "url": "@Url.Action("GetProjectsData", "Project")",
                    "type": "POST",
                    "error": function (xhr, error, thrown) {
                        console.error('DataTables AJAX error:', error, thrown);
                    }
                },
                "order": [[0, "asc"]],
                "pageLength": 50,
                "lengthMenu": [10, 25, 50, 100, 250],
                "columns": [
                    { "data": "projectTitle" },
                    { "data": "description" },
                    {
                        "data": "categoryName",
                        "render": function (data) {
                            return '<span class="badge bg-info">' + data + '</span>';
                        }
                    },
                    {
                        "data": "difficultyLevel",
                        "render": function (data) {
                            switch (data) {
                                case "Easy":
                                case "Kolay":
                                    return '<span class="badge bg-success">Kolay</span>';
                                case "Medium":
                                case "Orta":
                                    return '<span class="badge bg-warning">Orta</span>';
                                case "Hard":
                                case "Zor":
                                    return '<span class="badge bg-danger">Zor</span>';
                                default:
                                    return '<span class="badge bg-secondary">' + data + '</span>';
                            }
                        }
                    },
                    {
                        "data": "completionPercentage",
                        "render": function (data) {
                            var color = data < 30 ? "bg-danger" : data < 70 ? "bg-warning" : "bg-success";
                            return '<div class="d-flex align-items-center">' +
                                '<div class="progress flex-grow-1" style="height: 8px; min-width: 60px;">' +
                                '<div class="progress-bar ' + color + '" role="progressbar" style="width: ' + data + '%;" aria-valuenow="' + data + '" aria-valuemin="0" aria-valuemax="100"></div>' +
                                '</div>' +
                                '<span class="badge ' + color + ' ms-2">%' + data + '</span>' +
                                '</div>';
                        }
                    },
                    { "data": "endDate" },
                    { "data": "createdByFullName" },
                    {
                        "data": "id",
                        "orderable": false,
                        "searchable": false,
                        "render": function (data) {
                            return '<div class="btn-group" role="group">' +
                                '<a href="/Project/Details/' + data + '" class="btn btn-sm btn-info text-white" title="İncele"><i class="bi bi-eye"></i></a>' +
                                '<a href="/Project/Edit/' + data + '" class="btn btn-sm btn-primary" title="Düzenle"><i class="bi bi-pencil-fill"></i></a>' +
                                '<a href="/Teacher/AssignStudentsToProject?projectId=' + data + '" class="btn btn-sm btn-success" title="Öğrenci Ata"><i class="bi bi-person-plus-fill"></i></a>' +
                                '<a href="/Teacher/ViewProjectStudents?projectId=' + data + '" class="btn btn-sm btn-info" title="Atanmış Öğrenciler"><i class="bi bi-people-fill"></i></a>' +
                                '<a href="/Project/Delete/' + data + '" class="btn btn-sm btn-danger" onclick="return confirm(\'Bu projeyi çöp kutusuna taşımak istediğinize emin misiniz?\');" title="Sil"><i class="bi bi-trash-fill"></i></a>' +
                                '</div>';
                        }
                    }
                ],
                "language": {
                    "decimal": "",
                    "emptyTable": "Tabloda herhangi bir veri mevcut değil",
                    "info": "_TOTAL_ kayıttan _START_ - _END_ arasındaki kayıtlar gösteriliyor",
                    "infoEmpty": "Kayıt yok",
                    "infoFiltered": "(_MAX_ kayıt içerisinden bulunan)",
                    "infoPostFix": "",
                    "thousands": ".",
                    "lengthMenu": "Sayfada _MENU_ kayıt göster",
                    "loadingRecords": "Yükleniyor...",
                    "processing": '<div class="d-flex justify-content-center align-items-center"><div class="spinner-border text-primary me-2" role="status"></div> İşleniyor...</div>',
                    "search": "Ara:",
                    "zeroRecords": "Eşleşen kayıt bulunamadı",
                    "paginate": {
                        "first": "İlk",
                        "last": "Son",
                        "next": "Sonraki",
                        "previous": "Önceki"
                    },
                    "aria": {
                        "sortAscending": ": artan sütun sıralamasını aktifleştir",
                        "sortDescending": ": azalan sütun sıralamasını aktifleştir"
                    }
                }
            });
        });
    </script>
}
