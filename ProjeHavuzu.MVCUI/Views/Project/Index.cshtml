@using Microsoft.AspNetCore.Identity
@using ProjeHavuzu.Data.DTOs.ProjectDto
@using ProjeHavuzu.Data.Entites.Identity
@model List<ProjectListDto>
@inject UserManager<AppUser> UserManager

@{
    ViewData["Title"] = "Proje Listesi";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml"; 
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Proje Listesi</h3>
        <div>
             <a asp-action="RecycleBin" class="btn btn-warning me-2">
                <i class="bi bi-trash"></i> Çöp Kutusu
            </a>
            <a asp-action="Create" class="btn btn-success">
                <i class="bi bi-plus-lg"></i> Yeni Proje
            </a>
        </div>
    </div>
    
     @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <table class="table table-striped table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Başlık</th>
                <th>Açıklama</th>
                <th>Kategori</th>
                <th>Zorluk</th>
                <th>Bitiş Tarihi</th>
                <th>Oluşturan</th>
                <th>Link</th>
                <th>İşlemler</th>            
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.ProjectTitle</td>
                        <td>
                            @if(item.Description != null && item.Description.Length > 50)
                            {
                                @(item.Description.Substring(0, 50) + "...")
                            }
                            else
                            {
                                @item.Description
                            }
                        </td>
                        <td>@item.CategoryName</td>
                        <td>@item.DifficultyLevel</td>
                        <td>@item.EndDate.ToShortDateString()</td>
                        <td>@item.CreatedByFullName</td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(item.ProjectLink))
                            {
                                <a href="@item.ProjectLink" target="_blank" class="btn btn-sm btn-outline-primary mb-1">
                                    <i class="bi bi-link-45deg"></i> Link
                                </a>
                            }
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white" title="Detay">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary" title="Düzenle">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" onclick="return confirm('Bu projeyi silmek (çöp kutusuna taşımak) istediğinize emin misiniz?');" title="Sil">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center text-muted">
                        Kayıtlı proje bulunamadı.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
