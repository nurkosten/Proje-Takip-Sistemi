@using ProjeHavuzu.Data.DTOs.ProjectStudentDto
@model AssignStudentsToProjectDto

@{
    ViewData["Title"] = "Projeye Öğrenci Ata";
    var returnUrl = ViewBag.ReturnUrl as string ?? Url.Action("ProjectDetails", "Teacher", new { id = Model.ProjectId });
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-person-plus-fill"></i> Projeye Öğrenci Ata</h3>
        <a href="@returnUrl" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Geri Dön
        </a>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <h5 class="card-title">Proje Bilgileri</h5>
            <p><strong>Proje Adı:</strong> @Model.ProjectTitle</p>

        </div>
    </div>

    <form asp-controller="Teacher" asp-action="AssignStudentsToProject" asp-route-projectId="@Model.ProjectId" method="post">
        <input type="hidden" name="returnUrl" value="@returnUrl" />
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Öğrenci Seçimi</h5>
            </div>
            <div class="card-body">
                @if (Model.AvailableStudents != null && Model.AvailableStudents.Any())
                {
                <div class="row align-items-center mb-3">
                    <div class="col-md-6 mb-2 mb-md-0">
                        <button type="button" class="btn btn-sm btn-outline-primary" onclick="selectAll()">
                            <i class="bi bi-check-all"></i> Tümünü Seç
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="deselectAll()">
                            <i class="bi bi-x-lg"></i> Tümünü Kaldır
                        </button>
                    </div>
                    <div class="col-md-6">
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                            <input type="text" id="studentSearchInput" class="form-control" placeholder="Öğrenci ara (Ad, No, Email, Bölüm)..." onkeyup="filterStudents()">
                        </div>
                    </div>
                </div>

                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 50px;">
                                        <input type="checkbox" id="selectAllCheckbox" onchange="toggleAll(this)" />
                                    </th>
                                    <th>Öğrenci Adı</th>
                                    <th>Öğrenci No</th>
                                    <th>E-posta</th>
                                    <th>Bölüm</th>
                                    <th>Durum</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var student in Model.AvailableStudents)
                                {
                                    <tr class="@(student.IsAssigned ? "table-success" : "")">
                                        <td>
                                            <input type="checkbox" name="selectedStudentIds" value="@student.StudentId"
                                                class="student-checkbox" @(student.IsAssigned ? "checked" : "") />
                                        </td>
                                        <td>@student.FullName</td>
                                        <td>@student.StudentNumber</td>
                                        <td>@student.Email</td>
                                        <td>@student.DepartmentName</td>
                                        <td>
                                            @if (student.IsAssigned)
                                            {
                                                <span class="badge bg-success">Atanmış</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Atanmamış</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted text-center">Sistemde kayıtlı öğrenci bulunmamaktadır.</p>
                }
            </div>
            <div class="card-footer">
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-save"></i> Kaydet
                </button>
                <a href="@returnUrl" class="btn btn-secondary">
                    <i class="bi bi-x-circle"></i> İptal
                </a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function toggleAll(source) {
            const checkboxes = document.querySelectorAll('.student-checkbox');
            // Sadece görünür olan checkbox'ları seç/kaldır
            checkboxes.forEach(checkbox => {
                const row = checkbox.closest('tr');
                if (row.style.display !== 'none') {
                    checkbox.checked = source.checked;
                }
            });
        }

        function selectAll() {
            const checkboxes = document.querySelectorAll('.student-checkbox');
            checkboxes.forEach(checkbox => {
                const row = checkbox.closest('tr');
                if (row.style.display !== 'none') {
                    checkbox.checked = true;
                }
            });
            // Eğer tüm görünürler seçiliyse ana checkbox'ı da işaretle (basitleştirilmiş mantık)
            document.getElementById('selectAllCheckbox').checked = true;
        }

        function deselectAll() {
            const checkboxes = document.querySelectorAll('.student-checkbox');
            checkboxes.forEach(checkbox => {
                const row = checkbox.closest('tr');
                if (row.style.display !== 'none') {
                    checkbox.checked = false;
                }
            });
            document.getElementById('selectAllCheckbox').checked = false;
        }

        function filterStudents() {
            const input = document.getElementById('studentSearchInput');
            const filter = input.value.toLowerCase().trim();
            const table = document.querySelector('table tbody');
            const rows = table.getElementsByTagName('tr');

            for (let i = 0; i < rows.length; i++) {
                const nameCell = rows[i].getElementsByTagName('td')[1];
                const noCell = rows[i].getElementsByTagName('td')[2];
                const emailCell = rows[i].getElementsByTagName('td')[3];
                const deptCell = rows[i].getElementsByTagName('td')[4];

                if (nameCell && noCell && emailCell && deptCell) {
                    const nameText = nameCell.textContent || nameCell.innerText;
                    const noText = noCell.textContent || noCell.innerText;
                    const emailText = emailCell.textContent || emailCell.innerText;
                    const deptText = deptCell.textContent || deptCell.innerText;

                    if (nameText.toLowerCase().indexOf(filter) > -1 || 
                        noText.toLowerCase().indexOf(filter) > -1 || 
                        emailText.toLowerCase().indexOf(filter) > -1 || 
                        deptText.toLowerCase().indexOf(filter) > -1) {
                        rows[i].style.display = "";
                    } else {
                        rows[i].style.display = "none";
                    }
                }
            }
        }
    </script>
}
