@{
    ViewData["Title"] = "Akademisyen Paneli";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <h2 class="mb-4">Akademisyen Paneli</h2>
            <p class="lead">Akademisyen paneline hoş geldiniz. Burada tüm projeleri yönetebilir ve öğrenci atamalarını yapabilirsiniz.</p>
        </div>
    </div>

    <div class="row mt-4">
        <!-- Project Requests Card (Notification) -->
        <div class="col-md-12 mb-4">
            @{
                var pendingCount = ViewBag.PendingRequestCount as int? ?? 0;
                var cardClass = pendingCount > 0 ? "border-warning bg-light" : "";
            }
            <div class="card shadow-sm h-100 @cardClass">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="card-title mb-1">
                            <i class="bi bi-envelope-exclamation-fill text-warning"></i> Proje Katılım İstekleri
                        </h5>
                        <p class="card-text mb-0">
                            @if (pendingCount > 0)
                            {
                                <span class="text-danger fw-bold">Şu anda onay bekleyen @pendingCount adet yeni proje isteği var.</span>
                            }
                            else
                            {
                                <span>Bekleyen yeni bir proje isteği bulunmuyor.</span>
                            }
                        </p>
                    </div>
                    <a asp-action="ProjectRequests" class="btn @(pendingCount > 0 ? "btn-warning" : "btn-outline-secondary") position-relative">
                        İstekleri Görüntüle
                        @if (pendingCount > 0)
                        {
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                @pendingCount
                                <span class="visually-hidden">bekleyen istek</span>
                            </span>
                        }
                    </a>
                </div>
            </div>
        </div>

        <!-- All Projects Card -->
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="bi bi-folder-fill text-primary"></i> Tüm Projeler
                    </h5>
                    <p class="card-text">Tüm kullanıcılar tarafından eklenen projeleri görüntüleyin, düzenleyin ve silin.</p>
                    <a asp-action="AllProjects" class="btn btn-primary">
                        <i class="bi bi-box-arrow-up-right"></i> Projelere Git
                    </a>
                </div>
            </div>
        </div>

        <!-- Project Management Card -->
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="bi bi-people-fill text-success"></i> Öğrenci Yönetimi
                    </h5>
                    <p class="card-text">Projelere öğrenci atayın veya öğrencilere proje atayın.</p>
                    <a asp-action="Students" class="btn btn-success">
                        <i class="bi bi-person-plus-fill"></i> Atama Yap
                    </a>
                </div>
            </div>
        </div>
              
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
    }
</div>
