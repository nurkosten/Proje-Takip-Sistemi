@{
    ViewData["Title"] = "Teacher Dashboard";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <h2 class="mb-4">Teacher Dashboard</h2>
            <p class="lead">Öğretmen paneline hoş geldiniz. Burada tüm projeleri yönetebilir ve öğrenci atamalarını yapabilirsiniz.</p>
        </div>
    </div>

    <div class="row mt-4">
        <!-- All Projects Card -->
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="bi bi-folder-fill text-primary"></i> Tüm Projeler
                    </h5>
                    <p class="card-text">Tüm kullanıcılar tarafından eklenen projeleri görüntüleyin, düzenleyin ve silin.</p>
                    <a asp-action="AllProjects" class="btn btn-primary">
                        <i class="bi bi-box-arrow-up-right"></i> Projelere Git
                    </a>
                </div>
            </div>
        </div>

        <!-- Project Management Card -->
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="bi bi-people-fill text-success"></i> Öğrenci Yönetimi
                    </h5>
                    <p class="card-text">Projelere öğrenci atayın veya öğrencilere proje atayın.</p>
                    <a asp-action="Students" class="btn btn-success">
                        <i class="bi bi-person-plus-fill"></i> Atama Yap
                    </a>
                </div>
            </div>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
    }
</div>
