@using ProjeHavuzu.Data.DTOs.ProjectDto
@model ProjectCreateDto

@{
    ViewData["Title"] = "Proje Düzenle";
    var projectId = ViewBag.ProjectId;
    var returnUrl = ViewBag.ReturnUrl as string ?? Url.Action("ProjectDetails", "Teacher", new { id = projectId });

    ViewData["IsEdit"] = true;
    ViewData["FormId"] = "editProjectForm";
    ViewData["FormController"] = "Teacher";
    ViewData["FormAction"] = "EditProject";
    ViewData["ProjectId"] = projectId;
    ViewData["ReturnUrl"] = returnUrl;
    ViewData["CancelUrl"] = returnUrl;
    ViewData["PageTitle"] = "Proje Düzenle";
    ViewData["PageDescription"] = "Mevcut proje bilgilerini güncelleyebilirsiniz.";
    ViewData["SubmitText"] = "Değişiklikleri Kaydet";
    ViewData["LanguagesJson"] = Model.SelectedLanguagesJson ?? "";
}

@await Html.PartialAsync("_ProjectFormBody", Model)

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @{
        ViewData["FormId"] = "editProjectForm";
        ViewData["IsEdit"] = true;
        ViewData["LanguagesJson"] = Model.SelectedLanguagesJson ?? "";
    }
    @await Html.PartialAsync("_ProjectFormScripts")
}
