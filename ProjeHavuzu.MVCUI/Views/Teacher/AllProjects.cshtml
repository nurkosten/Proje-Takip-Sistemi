@using ProjeHavuzu.Data.DTOs.ProjectDto
@model List<ProjectListDto>

@{
    ViewData["Title"] = "All Projects";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-folder-fill"></i> Tüm Projeler</h3>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Dashboard'a Dön
        </a>
    </div>

    <!-- Search Box -->
    <div class="row mb-3">
        <div class="col-md-6">
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" id="searchInput" class="form-control" placeholder="Proje adı, kategori veya oluşturan kişi ara...">
                <button class="btn btn-outline-secondary" type="button" id="clearSearch">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </div>
        <div class="col-md-3">
            <select id="difficultyFilter" class="form-select">
                <option value="">Tüm Zorluklar</option>
                <option value="Kolay">Kolay</option>
                <option value="Orta">Orta</option>
                <option value="Zor">Zor</option>
            </select>
        </div>
        <div class="col-md-3">
            <span id="resultCount" class="badge bg-primary fs-6 p-2"></span>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-striped table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Proje Adı</th>
                    <th>Açıklama</th>
                    <th>Kategori</th>
                    <th>Zorluk</th>
                    <th>Bitiş Tarihi</th>
                    <th>Oluşturan</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ProjectTitle</td>
                            <td>@(item.Description.Length > 50 ? item.Description.Substring(0, 50) + "..." : item.Description)</td>
                            <td><span class="badge bg-info">@item.CategoryName</span></td>
                            <td>
                                @switch (item.DifficultyLevel.ToString())
                                {
                                    case "Easy":
                                        <span class="badge bg-success">Kolay</span>
                                        break;
                                    case "Medium":
                                        <span class="badge bg-warning">Orta</span>
                                        break;
                                    case "Hard":
                                        <span class="badge bg-danger">Zor</span>
                                        break;
                                    default:
                                        <span class="badge bg-secondary">@item.DifficultyLevel</span>
                                        break;
                                }
                            </td>
                            <td>@item.EndDate.ToShortDateString()</td>
                            <td>@item.CreatedByFullName</td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="EditProject" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Düzenle">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>
                                    <a asp-action="AssignStudentsToProject" asp-route-projectId="@item.Id" class="btn btn-sm btn-success" title="Öğrenci Ata">
                                        <i class="bi bi-person-plus-fill"></i>
                                    </a>
                                    <a asp-action="ViewProjectStudents" asp-route-projectId="@item.Id" class="btn btn-sm btn-info" title="Atanmış Öğrenciler">
                                        <i class="bi bi-people-fill"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-danger" onclick="confirmDelete('@item.Id', '@item.ProjectTitle')" title="Sil">
                                        <i class="bi bi-trash-fill"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted">
                            Henüz proje bulunmamaktadır.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Projeyi Sil</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Bu projeyi silmek istediğinizden emin misiniz?</p>
                <p><strong id="projectToDelete"></strong></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                <form id="deleteForm" method="post" style="display:inline;">
                    <button type="submit" class="btn btn-danger">Sil</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(projectId, projectTitle) {
            document.getElementById('projectToDelete').textContent = projectTitle;
            document.getElementById('deleteForm').action = '@Url.Action("DeleteProject", "Teacher")' + '?id=' + projectId;
            var deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));
            deleteModal.show();
        }

        // Search and Filter Functionality
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('searchInput');
            const difficultyFilter = document.getElementById('difficultyFilter');
            const clearSearch = document.getElementById('clearSearch');
            const resultCount = document.getElementById('resultCount');
            const tableBody = document.querySelector('table tbody');
            const rows = tableBody ? tableBody.querySelectorAll('tr') : [];

            function filterTable() {
                const searchTerm = searchInput.value.toLowerCase().trim();
                const difficulty = difficultyFilter.value;
                let visibleCount = 0;

                rows.forEach(row => {
                    const cells = row.querySelectorAll('td');
                    if (cells.length === 0) return; // Skip if no data cells

                    const projectName = cells[0]?.textContent?.toLowerCase() || '';
                    const description = cells[1]?.textContent?.toLowerCase() || '';
                    const category = cells[2]?.textContent?.toLowerCase() || '';
                    const rowDifficulty = cells[3]?.textContent?.trim() || '';
                    const creator = cells[5]?.textContent?.toLowerCase() || '';

                    const matchesSearch = !searchTerm || 
                        projectName.includes(searchTerm) || 
                        description.includes(searchTerm) ||
                        category.includes(searchTerm) || 
                        creator.includes(searchTerm);

                    const matchesDifficulty = !difficulty || rowDifficulty === difficulty;

                    if (matchesSearch && matchesDifficulty) {
                        row.style.display = '';
                        visibleCount++;
                    } else {
                        row.style.display = 'none';
                    }
                });

                resultCount.textContent = visibleCount + ' proje bulundu';
            }

            // Initial count
            resultCount.textContent = rows.length + ' proje bulundu';

            searchInput.addEventListener('input', filterTable);
            difficultyFilter.addEventListener('change', filterTable);
            
            clearSearch.addEventListener('click', function() {
                searchInput.value = '';
                difficultyFilter.value = '';
                filterTable();
            });
        });
    </script>
}
