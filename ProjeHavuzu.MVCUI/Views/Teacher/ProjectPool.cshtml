@using ProjeHavuzu.Data.DTOs.ProjectDto
@model List<ProjectListDto>

@{
    ViewData["Title"] = "Proje Havuzu";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-collection"></i> Proje Havuzu</h3>
        <a asp-action="Index" asp-controller="Home" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Ana Sayfaya Dön
        </a>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Search and Filter -->
    <div class="row mb-4">
        <div class="col-md-5">
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" id="searchInput" class="form-control" placeholder="Proje adı, kategori veya açıklama ara...">
                <button class="btn btn-outline-secondary" type="button" id="clearSearch">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </div>
        <div class="col-md-3">
            <select id="difficultyFilter" class="form-select">
                <option value="">Tüm Zorluklar</option>
                <option value="Kolay">Kolay</option>
                <option value="Orta">Orta</option>
                <option value="Zor">Zor</option>
            </select>
        </div>
        <div class="col-md-3">
            <select id="categoryFilter" class="form-select">
                <option value="">Tüm Kategoriler</option>
                @if (Model != null)
                {
                    @foreach (var cat in Model.Select(p => p.CategoryName).Distinct().OrderBy(c => c))
                    {
                        <option value="@cat">@cat</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-1">
            <span id="resultCount" class="badge bg-primary fs-6 p-2"></span>
        </div>
    </div>

    <!-- Projects Grid -->
    <div class="row" id="projectsContainer">
        @if (Model != null && Model.Any())
        {
            @foreach (var project in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4 project-card" 
                     data-title="@project.ProjectTitle.ToLower()" 
                     data-category="@project.CategoryName"
                     data-description="@project.Description.ToLower()"
                     data-difficulty="@(project.DifficultyLevel.ToString() == "Easy" ? "Kolay" : project.DifficultyLevel.ToString() == "Medium" ? "Orta" : project.DifficultyLevel.ToString() == "Hard" ? "Zor" : project.DifficultyLevel.ToString())">
                    <div class="card h-100 shadow-sm">
                        <div class="card-header bg-light">
                            <h5 class="card-title mb-0 text-truncate" title="@project.ProjectTitle">
                                <i class="bi bi-folder-fill text-primary"></i> @project.ProjectTitle
                            </h5>
                        </div>
                        <div class="card-body">
                            <p class="card-text text-muted" style="height: 60px; overflow: hidden;">
                                @(project.Description.Length > 100 ? project.Description.Substring(0, 100) + "..." : project.Description)
                            </p>
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                <span class="badge bg-info">@project.CategoryName</span>
                                @switch (project.DifficultyLevel.ToString())
                                {
                                    case "Easy":
                                        <span class="badge bg-success">Kolay</span>
                                        break;
                                    case "Medium":
                                        <span class="badge bg-warning text-dark">Orta</span>
                                        break;
                                    case "Hard":
                                        <span class="badge bg-danger">Zor</span>
                                        break;
                                    default:
                                        <span class="badge bg-secondary">@project.DifficultyLevel</span>
                                        break;
                                }
                                <span class="badge bg-secondary"><i class="bi bi-calendar-event"></i> @project.EndDate.ToShortDateString()</span>
                            </div>
                            <small class="text-muted">
                                <i class="bi bi-person"></i> @project.CreatedByFullName
                            </small>
                        </div>
                        <div class="card-footer bg-white border-top-0">
                            <a asp-action="ProjectDetails" asp-route-id="@project.Id" class="btn btn-primary btn-sm w-100">
                                <i class="bi bi-eye"></i> Detayları Görüntüle
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info text-center">
                    <i class="bi bi-info-circle fs-1"></i>
                    <h5 class="mt-3">Henüz proje bulunmuyor.</h5>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('searchInput');
            const difficultyFilter = document.getElementById('difficultyFilter');
            const categoryFilter = document.getElementById('categoryFilter');
            const clearSearch = document.getElementById('clearSearch');
            const resultCount = document.getElementById('resultCount');
            const projectCards = document.querySelectorAll('.project-card');

            function filterProjects() {
                const searchTerm = searchInput.value.toLowerCase().trim();
                const selectedDifficulty = difficultyFilter.value;
                const selectedCategory = categoryFilter.value;
                let visibleCount = 0;

                projectCards.forEach(card => {
                    const title = card.dataset.title || '';
                    const category = card.dataset.category || '';
                    const description = card.dataset.description || '';
                    const difficulty = card.dataset.difficulty || '';

                    const matchesSearch = !searchTerm || 
                        title.includes(searchTerm) || 
                        category.toLowerCase().includes(searchTerm) ||
                        description.includes(searchTerm);

                    const matchesDifficulty = !selectedDifficulty || difficulty === selectedDifficulty;
                    const matchesCategory = !selectedCategory || category === selectedCategory;

                    if (matchesSearch && matchesDifficulty && matchesCategory) {
                        card.style.display = '';
                        visibleCount++;
                    } else {
                        card.style.display = 'none';
                    }
                });

                resultCount.textContent = visibleCount + ' proje';
            }

            // Initial count
            resultCount.textContent = projectCards.length + ' proje';

            searchInput.addEventListener('input', filterProjects);
            difficultyFilter.addEventListener('change', filterProjects);
            categoryFilter.addEventListener('change', filterProjects);
            
            clearSearch.addEventListener('click', function() {
                searchInput.value = '';
                difficultyFilter.value = '';
                categoryFilter.value = '';
                filterProjects();
            });
        });
    </script>
}
