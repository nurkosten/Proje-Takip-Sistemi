@using ProjeHavuzu.Data.DTOs.ProjectDto
@using ProjeHavuzu.Data.Entites.Enums
@model List<ProjectListDto>

@{
    ViewData["Title"] = "Danışman Projeleri";
}

<div class="container-fluid mt-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0 fw-bold" style="color: #003366;">
            <i class="bi bi-journal-check me-2"></i>Danışman Projeleri
        </h3>
        <a asp-action="Index" class="btn btn-outline-dark rounded-pill px-4">
            <i class="bi bi-arrow-left me-1"></i> Panel Ana Sayfası
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert" style="border-left: 4px solid #059669 !important;">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm" role="alert" style="border-left: 4px solid #dc2626 !important;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm border-0" style="border-radius: 12px;">
        <div class="card-header py-3" style="background: linear-gradient(135deg, #003366 0%, #004080 100%);">
            <h5 class="mb-0 text-white fw-bold">
                <i class="bi bi-folder2-open me-2"></i>Bana Gönderilen Projeler
                <span class="badge bg-white text-dark rounded-pill ms-2 fw-semibold" style="font-size: .75rem;">@(Model?.Count ?? 0)</span>
            </h5>
        </div>
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0" id="advisorProjectsTable">
                        <thead>
                            <tr style="background: #f8fafc; border-bottom: 2px solid #e5e9f0;">
                                <th class="ps-4 py-3" style="color: #475569; font-weight: 600; font-size: .8rem; text-transform: uppercase;">Proje Adı</th>
                                <th class="py-3" style="color: #475569; font-weight: 600; font-size: .8rem; text-transform: uppercase;">Kategori</th>
                                <th class="py-3" style="color: #475569; font-weight: 600; font-size: .8rem; text-transform: uppercase;">Öğrenci</th>
                                <th class="py-3" style="color: #475569; font-weight: 600; font-size: .8rem; text-transform: uppercase;">Oluşturulma</th>
                                <th class="py-3" style="color: #475569; font-weight: 600; font-size: .8rem; text-transform: uppercase;">Onay Durumu</th>
                                <th class="py-3 text-center no-sort" style="color: #475569; font-weight: 600; font-size: .8rem; text-transform: uppercase;">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var project in Model)
                            {
                                <tr style="border-bottom: 1px solid #f1f3f7;">
                                    <td class="ps-4 py-3">
                                        <strong style="color: #1e293b;">@project.ProjectTitle</strong>
                                    </td>
                                    <td class="py-3" style="color: #64748b;">@project.CategoryName</td>
                                    <td class="py-3" style="color: #64748b;">@project.CreatedByFullName</td>
                                    <td class="py-3" style="color: #64748b;">@project.CreatedDate.ToString("dd.MM.yyyy")</td>
                                    <td class="py-3">
                                        @switch (project.ApprovalStatus)
                                        {
                                            case ProjectApprovalStatus.Pending:
                                                <span class="badge rounded-pill" style="background: #fef3c7; color: #92400e;">Danışman Onayı Bekliyor</span>
                                                break;
                                            case ProjectApprovalStatus.Approved:
                                                <span class="badge rounded-pill" style="background: #d1fae5; color: #065f46;">Onaylandı</span>
                                                break;
                                            case ProjectApprovalStatus.Rejected:
                                                <span class="badge rounded-pill" style="background: #fee2e2; color: #991b1b;">Reddedildi</span>
                                                @if (!string.IsNullOrWhiteSpace(project.RejectionReason))
                                                {
                                                    <div class="small text-dark mt-1">Red Sebebi: @project.RejectionReason</div>
                                                }
                                                break;
                                        }
                                    </td>
                                    <td class="py-3 text-center">
                                        @if (project.ApprovalStatus == ProjectApprovalStatus.Pending)
                                        {
                                            <form asp-action="ApproveProject" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@project.Id" />
                                                <button type="submit" class="btn btn-sm btn-success me-1" title="Onayla">
                                                    <i class="bi bi-check-lg"></i> Onayla
                                                </button>
                                            </form>
                                            <button type="button"
                                                    class="btn btn-sm btn-danger btn-reject-project"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#rejectProjectModal"
                                                    data-project-id="@project.Id"
                                                    data-project-title="@project.ProjectTitle">
                                                <i class="bi bi-x-lg"></i> Reddet
                                            </button>
                                        }
                                        else if (project.ApprovalStatus == ProjectApprovalStatus.Approved)
                                        {
                                            <span class="badge bg-success">Onaylandı</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Reddedildi</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5 px-4">
                    <i class="bi bi-inbox" style="font-size: 2rem; color: #94a3b8;"></i>
                    <h5 class="mt-3 fw-semibold" style="color: #1e293b;">Henüz size gönderilmiş proje yok</h5>
                    <p class="mb-0" style="color: #94a3b8;">Öğrenciler proje oluşturup sizi danışman seçtiğinde burada görünecektir.</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Reddetme modalı tablo dışında (backdrop / overflow sorununu önler) -->
<div class="modal fade" id="rejectProjectModal" tabindex="-1" aria-labelledby="rejectProjectModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius: 12px;">
            <form asp-action="RejectProject" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="rejectProjectId" />
                <div class="modal-header border-0 py-3" style="background: linear-gradient(135deg, #dc2626, #ef4444);">
                    <h5 class="modal-title text-white fw-bold" id="rejectProjectModalLabel">
                        <i class="bi bi-x-circle me-2"></i>Projeyi Reddet
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Kapat"></button>
                </div>
                <div class="modal-body p-4">
                    <p class="mb-3" style="color: #334155;">
                        <strong id="rejectProjectTitle"></strong> projesini reddetmek üzeresiniz.
                    </p>
                    <div class="mb-0">
                        <label for="rejectionReason" class="form-label fw-bold">Red Açıklaması <span class="text-danger">*</span></label>
                        <textarea id="rejectionReason" name="rejectionReason" class="form-control" rows="4" required placeholder="Red nedenini yazınız..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 px-4 pb-4">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-3" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn text-white rounded-pill px-4" style="background: linear-gradient(135deg, #dc2626, #ef4444); border: none;">
                        <i class="bi bi-x-lg me-1"></i> Reddet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var rejectModal = document.getElementById('rejectProjectModal');
            if (!rejectModal) return;

            rejectModal.addEventListener('show.bs.modal', function (event) {
                var button = event.relatedTarget;
                if (!button) return;

                document.getElementById('rejectProjectId').value = button.getAttribute('data-project-id') || '';
                document.getElementById('rejectProjectTitle').textContent = button.getAttribute('data-project-title') || '';
                document.getElementById('rejectionReason').value = '';
            });

            rejectModal.addEventListener('hidden.bs.modal', function () {
                document.getElementById('rejectionReason').value = '';
            });
        })();
    </script>
}
