
@using ProjeHavuzu.Data.Entites
@model List<ProjectRequest>

@{
    ViewData["Title"] = "Gelen Proje İstekleri";
}

<div class="container-fluid mt-4 px-4">
    <!-- Sayfa Başlığı -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0 fw-bold" style="color: #003366;">
            <i class="bi bi-inbox-fill me-2"></i>Gelen Proje İstekleri
        </h3>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-dark rounded-pill px-4">
            <i class="bi bi-arrow-left me-1"></i> Ana Sayfa
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert" style="border-left: 4px solid #059669 !important;">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm" role="alert" style="border-left: 4px solid #dc2626 !important;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- İstek Kartı -->
    <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
        <div class="card-header py-3" style="background: linear-gradient(135deg, #003366 0%, #004080 100%);">
            <h5 class="mb-0 text-white fw-bold">
                <i class="bi bi-envelope-paper me-2"></i>Bekleyen İstekler
                <span class="badge bg-white text-dark rounded-pill ms-2 fw-semibold" style="font-size: .75rem;">@(Model?.Count ?? 0)</span>
            </h5>
        </div>
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr style="background: #f8fafc; border-bottom: 2px solid #e5e9f0;">
                                <th class="ps-4 py-3" style="color: #475569; font-weight: 600; font-size: .8rem; text-transform: uppercase; letter-spacing: .05em;">Öğrenci</th>
                                <th class="py-3" style="color: #475569; font-weight: 600; font-size: .8rem; text-transform: uppercase; letter-spacing: .05em;">Proje</th>
                                <th class="py-3" style="color: #475569; font-weight: 600; font-size: .8rem; text-transform: uppercase; letter-spacing: .05em;">İstek Tarihi</th>
                                <th class="py-3" style="color: #475569; font-weight: 600; font-size: .8rem; text-transform: uppercase; letter-spacing: .05em;">Öğrenci Mesajı</th>
                                <th class="py-3 text-center" style="color: #475569; font-weight: 600; font-size: .8rem; text-transform: uppercase; letter-spacing: .05em;">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var request in Model)
                            {
                                <tr style="border-bottom: 1px solid #f1f3f7;">
                                    <td class="ps-4 py-3">
                                        <div class="d-flex align-items-center">
                                            <div class="me-3" style="width: 36px; height: 36px; background: linear-gradient(135deg, #003366, #336699); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                                                <i class="bi bi-person-fill text-white" style="font-size: .85rem;"></i>
                                            </div>
                                            <div>
                                                <strong style="color: #1e293b;">@request.Student?.FullName</strong><br />
                                                <small style="color: #94a3b8; font-size: .75rem;">@request.Student?.Email</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-3">
                                        <span class="fw-medium" style="color: #334155;">@request.Project?.ProjectTitle</span>
                                    </td>
                                    <td class="py-3">
                                        <span style="color: #64748b; font-size: .84rem;">
                                            <i class="bi bi-calendar3 me-1" style="font-size: .7rem;"></i>@request.RequestDate.ToString("dd.MM.yyyy HH:mm")
                                        </span>
                                    </td>
                                    <td class="py-3" style="color: #64748b; font-size: .84rem; max-width: 250px;">
                                        @(string.IsNullOrEmpty(request.Message) ? "-" : request.Message)
                                    </td>
                                    <td class="py-3 text-center">
                                        <div class="btn-group" role="group">
                                            <button type="button" class="btn btn-sm text-white" 
                                                    style="background: linear-gradient(135deg, #059669, #10b981); border: none; border-radius: 6px 0 0 6px;"
                                                    data-bs-toggle="modal" 
                                                    data-bs-target="#approveModal"
                                                    data-request-id="@request.Id"
                                                    data-student-name="@request.Student?.FullName"
                                                    data-project-title="@request.Project?.ProjectTitle">
                                                <i class="bi bi-check-lg me-1"></i> Onayla
                                            </button>
                                            <button type="button" class="btn btn-sm text-white"
                                                    style="background: linear-gradient(135deg, #dc2626, #ef4444); border: none; border-radius: 0 6px 6px 0;"
                                                    data-bs-toggle="modal" 
                                                    data-bs-target="#rejectModal"
                                                    data-request-id="@request.Id"
                                                    data-student-name="@request.Student?.FullName"
                                                    data-project-title="@request.Project?.ProjectTitle">
                                                <i class="bi bi-x-lg me-1"></i> Reddet
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5 px-4">
                    <div class="mb-3" style="width: 64px; height: 64px; background: linear-gradient(135deg, #e8f0fe, #dbeafe); border-radius: 50%; display: inline-flex; align-items: center; justify-content: center;">
                        <i class="bi bi-envelope-open" style="font-size: 1.5rem; color: #003366;"></i>
                    </div>
                    <h5 class="mt-2 fw-semibold" style="color: #1e293b;">Bekleyen istek bulunmuyor</h5>
                    <p style="color: #94a3b8; font-size: .9rem;">Şu an için projenize katılmak isteyen yeni bir öğrenci isteği yok.</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Onaylama Modalı -->
<div class="modal fade" id="approveModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius: 12px; overflow: hidden;">
            <form asp-action="ApproveRequest" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="requestId" id="approveRequestId" />
                <div class="modal-header border-0 py-3" style="background: linear-gradient(135deg, #059669, #10b981);">
                    <h5 class="modal-title text-white fw-bold">
                        <i class="bi bi-check-circle me-2"></i>İsteği Onayla
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <p style="color: #334155;"><strong id="approveStudentName"></strong> isimli öğrencinin <strong id="approveProjectTitle"></strong> projesine katılım isteğini onaylıyor musunuz?</p>
                    <div class="mb-3">
                        <label for="approveMessage" class="form-label fw-medium" style="color: #475569; font-size: .85rem;">Öğrenciye Yanıtınız (İsteğe Bağlı)</label>
                        <textarea class="form-control" id="approveMessage" name="responseMessage" rows="3" style="border-radius: 8px; border-color: #e2e8f0;"></textarea>
                    </div>
                    <div class="alert border-0 small py-2 px-3" style="background: #fef3c7; color: #92400e; border-radius: 8px; border-left: 3px solid #f59e0b !important;">
                        <i class="bi bi-exclamation-triangle me-1"></i> Onayladığınızda öğrenci otomatik olarak projeye atanacaktır.
                    </div>
                </div>
                <div class="modal-footer border-0 px-4 pb-4">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-3" data-bs-dismiss="modal">Vazgeç</button>
                    <button type="submit" class="btn text-white rounded-pill px-4" style="background: linear-gradient(135deg, #059669, #10b981); border: none;">
                        <i class="bi bi-check-lg me-1"></i> Onayla ve Ata
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Reddetme Modalı -->
<div class="modal fade" id="rejectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius: 12px; overflow: hidden;">
            <form asp-action="RejectRequest" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="requestId" id="rejectRequestId" />
                <div class="modal-header border-0 py-3" style="background: linear-gradient(135deg, #dc2626, #ef4444);">
                    <h5 class="modal-title text-white fw-bold">
                        <i class="bi bi-x-circle me-2"></i>İsteği Reddet
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <p style="color: #334155;"><strong id="rejectStudentName"></strong> isimli öğrencinin <strong id="rejectProjectTitle"></strong> projesine katılım isteğini reddetmek istediğinize emin misiniz?</p>
                    <div class="mb-3">
                        <label for="rejectMessage" class="form-label fw-medium" style="color: #475569; font-size: .85rem;">Reddetme Nedeni / Mesajınız</label>
                        <textarea class="form-control" id="rejectMessage" name="responseMessage" rows="3" required placeholder="Lütfen bir neden belirtiniz..." style="border-radius: 8px; border-color: #e2e8f0;"></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 px-4 pb-4">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-3" data-bs-dismiss="modal">Vazgeç</button>
                    <button type="submit" class="btn text-white rounded-pill px-4" style="background: linear-gradient(135deg, #dc2626, #ef4444); border: none;">
                        <i class="bi bi-x-lg me-1"></i> İsteği Reddet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Modal veri aktarımı
        var approveModal = document.getElementById('approveModal');
        approveModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            document.getElementById('approveRequestId').value = button.getAttribute('data-request-id');
            document.getElementById('approveStudentName').textContent = button.getAttribute('data-student-name');
            document.getElementById('approveProjectTitle').textContent = button.getAttribute('data-project-title');
        });

        var rejectModal = document.getElementById('rejectModal');
        rejectModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            document.getElementById('rejectRequestId').value = button.getAttribute('data-request-id');
            document.getElementById('rejectStudentName').textContent = button.getAttribute('data-student-name');
            document.getElementById('rejectProjectTitle').textContent = button.getAttribute('data-project-title');
        });
    </script>
}
