@using ProjeHavuzu.Data.Entites.Identity
@model IList<AppUser>

@{
    ViewData["Title"] = "Öğrenci Listesi";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-people-fill"></i> Öğrenci Listesi</h3>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Dashboard'a Dön
        </a>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                    <div class="table-responsive">
                        <table class="table table-hover table-striped">
                            <thead class="table-light">
                                <tr>
                                    <th>Ad Soyad</th>
                                    <th>Öğrenci No</th>
                                    <th>E-posta</th>
                                    <th>Bölüm</th>
                                    <th>İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var student in Model)
                            {
                                        <tr>
                                            <td>@student.FullName</td>
                                            <td>@student.StudentNumber</td>
                                            <td>@student.Email</td>
                                            <td>@(student.Department?.DepartmentName ?? "-")</td>
                                            <td>
                                                <a asp-action="AssignProjectsToStudent" asp-route-studentId="@student.Id" class="btn btn-sm btn-success">
                                                    <i class="bi bi-folder-plus"></i> Proje Ata / Düzenle
                                                </a>
                                            </td>
                                        </tr>
                            }
                            </tbody>
                        </table>
                    </div>
            }
            else
            {
                    <div class="alert alert-info text-center">
                        <i class="bi bi-info-circle"></i> Sistemde kayıtlı öğrenci bulunmamaktadır.
                    </div>
            }
        </div>
    </div>
</div>
