@using ProjeHavuzu.Data.DTOs.FacultyDto
@model List<FacultyListDto>

@{
    ViewData["Title"] = "Fakülte Listesi";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">

            <div class="card shadow">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">Fakülteler</h4>
                    <a asp-action="Create" class="btn btn-success">
                        + Fakülte Ekle
                    </a>
                </div>

                <div class="card-body">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @if (Model == null || !Model.Any())
                    {
                        <div class="alert alert-warning">
                            Henüz fakülte eklenmedi.
                        </div>
                    }
                    else
                    {

                        <table class="table table-bordered table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Fakülte Adı</th>
                                    <th>İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.Count; i++)
                                {
                                    <tr>
                                        <td>@(i + 1)</td>
                                        <td>@Model[i].FacultyName</td>
                                        <td>
                                            <a asp-action="Edit" asp-route-id="@Model[i].Id" class="btn btn-sm btn-warning">
                                                <i class="bi bi-pencil"></i> Düzenle
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@Model[i].Id" class="btn btn-sm btn-danger">
                                                <i class="bi bi-trash"></i> Sil
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }

                </div>
            </div>

        </div>
    </div>
</div>
