
@model LoginViewModel
@{
    ViewData["Title"] = "Giriş Yap";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container" style="max-width: 420px; margin-top: 90px;">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">

            <h4 class="mb-1">Giriş Yap</h4>
            <p class="text-muted mb-4">Hesabına erişmek için bilgilerini gir.</p>

            @* Hata mesajları *@
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger py-2">
                    @Html.ValidationSummary(false)
                </div>
            }

            <form asp-action="Login" asp-controller="Login" method="post" autocomplete="off">
                <div class="mb-3">
                    <label class="form-label">Kullanıcı Adı / E-posta</label>
                    <input asp-for="UserNameOrEmail" class="form-control" placeholder="ornek@mail.com veya kullanıcı adı" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Şifre</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                </div>

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="RememberMe" />
                        <label class="form-check-label" asp-for="RememberMe">Beni hatırla</label>
                    </div>

                    <a class="small text-decoration-none" asp-controller="Account" asp-action="ForgotPassword">
                        Şifremi unuttum
                    </a>
                </div>

                <button type="submit" class="btn btn-primary w-100">Giriş</button>

                <div class="text-center mt-3">
                    <span class="text-muted small">Hesabın yok mu?</span>
                    <a class="small text-decoration-none" asp-controller="Account" asp-action="Register">Kayıt Ol</a>
                </div>
            </form>

        </div>
    </div>
</div>
